---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');

const t = {
  title: { en: "Projects", es: "Proyectos" }
};

const sWrap = "relative z-10 max-w-[1100px] w-full mx-auto px-6 md:px-10 shrink-0";

const T = {
  heading: "font-light tracking-tight text-white",
  subheading: "font-mono uppercase tracking-[0.2em] text-zinc-500",
  body: "text-zinc-400 leading-relaxed",
  meta: "text-zinc-600 italic",
  keywords: "font-mono text-zinc-600"
};
---

<Layout title="Projects">
  <main class="font-serif min-h-screen bg-[#121212] text-zinc-300 overflow-x-hidden relative flex flex-col justify-between antialiased selection:bg-blue-500/30 selection:text-white">
    <Header />
    
    <section class={`${sWrap} pt-12 md:pt-20 pb-8 md:pb-10 flex-1`}>
      <header class="mb-12 border-b border-white/[0.06] pb-8">
        <h1 class="leading-[0.95] tracking-[-0.02em] text-white font-light" style="font-size: clamp(48px, 8vw, 80px);" data-en={t.title.en} data-es={t.title.es}>
          {t.title.en}
        </h1>
      </header>

      <div class="flex flex-col">
        {projects.map((p) => (
          <a href={`/projects/${p.slug}`} class="group flex flex-col md:flex-row gap-4 md:gap-12 py-8 border-b border-white/[0.06] hover:bg-white/[0.02] transition-colors duration-500 px-4 -mx-4 rounded-lg">
            <div class="md:w-1/3">
              <div class="flex items-center gap-3">
	      	  <div class="w-1.5 h-1.5 rounded-full bg-zinc-600 group-hover:bg-white transition-colors duration-500 mt-1"></div>
                <h2 class={`${T.heading} text-[22px] md:text-[24px]`}>
                  {p.data.title}
                </h2>
              </div>
            </div>

            <div class="flex-1">
              <p class={`${T.body} text-[17px] md:text-[19px] mb-4`}>
                {p.data.description}
              </p>
              {p.data.tags && (
                <div class="flex flex-wrap gap-2">
                  {p.data.tags.map((tag: string) => (
                    <span class={`${T.keywords} text-[11px] uppercase tracking-widest border border-white/[0.06] px-2 py-0.5 group-hover:border-white/15 transition-colors duration-500`}>
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    </section>

    <Footer />
  </main>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap');
    
    .font-serif { 
      font-family: 'Crimson Text', Georgia, 'Times New Roman', serif; 
    }
    
    .font-mono {
      font-family: 'JetBrains Mono', 'Courier New', monospace;
    }
  </style>
</Layout>