---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const translations = {
    subtitle: { en: 'My Journey', es: 'Mi Trayectoria' },
    title: { en: 'Work Experience', es: 'Experiencia Laboral' },
    description: { en: '', es: '' }
};

const workExperience = [
    {
        year: 'August 2025 - January 2026',
        yearES: 'Agosto 2025 - Enero 2026',
        title: 'QA Backend Intern',
        titleES: 'Becario QA Backend',
        company: 'América Móvil / Global Hitss',
        description: 'QA Backend Intern for an América Móvil product, working under the Global Hitss team. Designed and executed API tests and automated test cases. Collaborated closely with the development team to identify, report, and track bugs, ensuring the quality and stability of backend services prior to production deployment.',
        descriptionES: 'Becario en el área de QA backend para producto de América Móvil, bajo el equipo de trabajo de Global Hitss. Realicé el diseño y ejecución de pruebas de API y automatización de casos de prueba. Colaboré estrechamente con el equipo de desarrollo para identificar, reportar y dar seguimiento a incidencias, asegurando la calidad y estabilidad de los servicios antes de su paso a producción.'
    }
];
---

<Layout title="Work | Luis Angel Moreno">
    <Header />
    
    <main class="min-h-screen px-4 sm:px-6 md:px-8 flex flex-col justify-center bg-white dark:bg-[#050505] transition-colors duration-500 selection:bg-[#e11d48]/20 selection:text-[#e11d48] dark:selection:text-white">
        <section class="max-w-4xl mx-auto w-full pt-32 pb-16 fade-in">
            
            <div class="mb-20">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-1.5 h-1.5 bg-[#e11d48]"></div>
                    <p class="text-[10px] font-mono text-zinc-500 tracking-[0.3em] uppercase" data-en={translations.subtitle.en} data-es={translations.subtitle.es}>{translations.subtitle.es}</p>
                </div>
                <h1 class="text-4xl md:text-6xl font-extrabold text-zinc-900 dark:text-white tracking-tighter mb-6" data-en={translations.title.en} data-es={translations.title.es}>
                    {translations.title.es}
                </h1>
                {translations.description.es && (
                    <p class="text-base sm:text-xl text-zinc-600 dark:text-zinc-400 font-light leading-relaxed max-w-2xl" data-en={translations.description.en} data-es={translations.description.es}>
                        {translations.description.es}
                    </p>
                )}
            </div>

            <div class="space-y-16 parallax-section">
                {
                    workExperience.map((work) => (
                        <div class="relative pl-8 md:pl-12 border-l border-zinc-200 dark:border-white/10 bg-transparent group transition-colors duration-700 hover:border-[#e11d48]/50">
                            
                            <div class="absolute -left-[5.5px] top-2 w-2.5 h-2.5 rotate-45 bg-zinc-300 dark:bg-zinc-800 border border-white dark:border-[#050505] group-hover:bg-[#e11d48] group-hover:border-[#e11d48] group-hover:shadow-[0_0_15px_rgba(225,29,72,0.5)] group-hover:scale-125 transition-all duration-500 ease-out"></div>
                            
                            <div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-4 gap-2 md:gap-0">
                                <h3 class="text-2xl md:text-3xl font-bold text-zinc-900 dark:text-zinc-100 group-hover:text-[#e11d48] transition-colors duration-500 tracking-tight" data-en={work.title} data-es={work.titleES}>
                                    {work.titleES}
                                </h3>
                                <span class="text-[10px] text-zinc-400 dark:text-zinc-500 font-mono tracking-[0.2em] uppercase mt-1 md:mt-0" data-en={work.year} data-es={work.yearES}>
                                    {work.yearES}
                                </span>
                            </div>
                            
                            <p class="text-[11px] font-mono uppercase tracking-[0.2em] text-zinc-500 dark:text-zinc-400 mb-6 pb-6 border-b border-zinc-200 dark:border-white/5 group-hover:border-[#e11d48]/20 transition-colors duration-500">
                                {work.company}
                            </p>
                            
                            <p class="text-sm sm:text-base text-zinc-700 dark:text-zinc-400 leading-relaxed font-light" data-en={work.description} data-es={work.descriptionES}>
                                {work.descriptionES}
                            </p>
                        </div>
                    ))
                }
            </div>
        </section>
    </main>

    <Footer />

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const observerOptions = {
                root: null,
                rootMargin: '0px',
                threshold: 0.1
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('.fade-in').forEach(el => {
                observer.observe(el);
            });

            window.addEventListener('scroll', () => {
                const scrolled = window.pageYOffset;
                document.querySelectorAll('.parallax-section').forEach(section => {
                    const speed = 0.05;
                    (section as HTMLElement).style.transform = `translateY(${scrolled * speed}px)`;
                });
            });
        });
    </script>
</Layout>