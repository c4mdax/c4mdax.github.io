---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const t = {
  title: { en: 'Work Experience', es: 'Experiencia Laboral' }
};

const workExperience = [
  {
    year: '2025 - 2026',
    title: 'QA Backend Intern',
    company: 'América Móvil / Global Hitss',
    description: 'QA Backend Intern for an América Móvil product. API testing, automated test case design, and bug tracking. Ensured service stability and quality prior to production deployment.'
  }
];
---

<Layout title="Work">
  <main class="min-h-screen bg-[#191919] text-zinc-700 overflow-x-hidden relative flex flex-col justify-between antialiased">
    <div class="absolute inset-0 opacity-[0.035] noise-bg pointer-events-none"></div>
    <div class="absolute inset-0 grid-overlay pointer-events-none"></div>

    <Header />
    
    <div class="flex-1 flex flex-col mt-12">
      <section class="max-w-[1000px] w-full mx-auto px-10 pt-12 pb-16 relative z-10">
        <header class="mb-20 border-b border-white/[0.05] pb-12">
          
          <h1 class="font-serif leading-none tracking-tight text-white font-light" style="font-size: clamp(40px, 6vw, 64px);" data-en={t.title.en} data-es={t.title.es}>
            {t.title.en}
          </h1>
        </header>

        <div class="flex flex-col font-mono">
          {workExperience.map((work) => (
            <div class="py-10 border-b border-white/[0.05]">
              <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-4 gap-2">
                <h3 class="text-[30px] text-white tracking-wide font-normal">
                  {work.title}
                </h3>
                <span class="text-[18px] text-zinc-500 uppercase tracking-widest">
                  {work.year}
                </span>
              </div>
              
              <p class="text-[18px] uppercase tracking-widest text-zinc-500 mb-6">
                {work.company}
              </p>
              
              <p class="text-[18px] leading-7 text-zinc-400 font-light max-w-[700px]">
                {work.description}
              </p>
            </div>
          ))}
        </div>
      </section>
    </div>

    <Footer />
  </main>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=IBM+Plex+Mono:wght@300;400;500&display=swap');
    .font-serif { font-family: 'Cormorant Garamond', serif; }
    .font-mono { font-family: 'IBM Plex Mono', monospace; }
    .noise-bg { background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E"); }
    .grid-overlay { background-size: 80px 80px; background-image: linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px); }
  </style>
</Layout>