---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const translations = {
    subtitle: { en: 'My Journey', es: 'Mi Trayectoria' },
    title: { en: 'Work Experience', es: 'Experiencia Laboral' },
    description: { en: '', es: '' }
};

const workExperience = [
    {
        year: 'August 2025 - January 2026',
        yearES: 'Agosto 2025 - Enero 2026',
        title: 'QA Backend Intern',
        titleES: 'Becario QA Backend',
        company: 'América Móvil / Global Hitss',
        description: 'QA Backend Intern for an América Móvil product, working under the Global Hitss team. Designed and executed API tests and automated test cases. Collaborated closely with the development team to identify, report, and track bugs, ensuring the quality and stability of backend services prior to production deployment.',
        descriptionES: 'Becario en el área de QA backend para producto de América Móvil, bajo el equipo de trabajo de Global Hitss. Realicé el diseño y ejecución de pruebas de API y automatización de casos de prueba. Colaboré estrechamente con el equipo de desarrollo para identificar, reportar y dar seguimiento a incidencias, asegurando la calidad y estabilidad de los servicios antes de su paso a producción.'
    }
];
---

<Layout title="Work | Luis Angel Moreno">
    <Header />
    
    <main class="min-h-screen px-4 sm:px-6 md:px-6 flex flex-col justify-center">
        <section class="max-w-3xl mx-auto w-full pt-32 pb-16 fade-in">
            <div class="mb-12 sm:mb-16">
                <p class="text-xs sm:text-sm font-medium text-gray-600 dark:text-gray-400 mb-3 sm:mb-4 tracking-wider uppercase" data-en={translations.subtitle.en} data-es={translations.subtitle.es}>{translations.subtitle.es}</p>
                <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 dark:text-white tracking-tight mb-4" data-en={translations.title.en} data-es={translations.title.es}>
                    {translations.title.es}
                </h1>
                <p class="text-sm sm:text-lg text-gray-600 dark:text-gray-400" data-en={translations.description.en} data-es={translations.description.es}>
                    {translations.description.es}
                </p>
            </div>

            <div class="space-y-12 parallax-section">
                {
                    workExperience.map((work) => (
                        <div class="relative pl-6 sm:pl-8 border-l-2 border-gray-200 dark:border-gray-800 bg-transparent group transition-colors duration-300 hover:border-[#58dbff] dark:hover:border-[#58dbff]">
                            <div class="absolute -left-[9px] top-1 w-4 h-4 rounded-full bg-gray-300 dark:bg-gray-700 group-hover:bg-[#58dbff] group-hover:shadow-[0_0_12px_rgba(88,219,255,0.6)] transition-all duration-300"></div>
                            
                            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-2 gap-1 sm:gap-0">
                                <h3 class="text-xl font-semibold text-gray-900 dark:text-white group-hover:text-[#58dbff] transition-colors duration-300" data-en={work.title} data-es={work.titleES}>
                                    {work.titleES}
                                </h3>
                                <span class="text-sm text-gray-500 dark:text-gray-500 font-mono" data-en={work.year} data-es={work.yearES}>
                                    {work.yearES}
                                </span>
                            </div>
                            
                            <p class="text-base text-gray-800 dark:text-gray-300 font-medium mb-3">
                                {work.company}
                            </p>
                            
                            <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 leading-relaxed" data-en={work.description} data-es={work.descriptionES}>
                                {work.descriptionES}
                            </p>
                        </div>
                    ))
                }
            </div>
        </section>
    </main>

    <Footer />

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const observerOptions = {
                root: null,
                rootMargin: '0px',
                threshold: 0.1
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('.fade-in').forEach(el => {
                observer.observe(el);
            });

            window.addEventListener('scroll', () => {
                const scrolled = window.pageYOffset;
                document.querySelectorAll('.parallax-section').forEach(section => {
                    const speed = 0.05;
                    (section as HTMLElement).style.transform = `translateY(${scrolled * speed}px)`;
                });
            });
        });
    </script>
</Layout>