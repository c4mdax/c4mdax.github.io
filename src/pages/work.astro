---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const t = {
  title: { en: 'Work Experience', es: 'Experiencia Laboral' }
};

const workExperience = [
  {
    year: { en: '2025 - Jan 2026', es: '2025 - Ene 2026' },
    title: { en: 'QA Backend Intern', es: 'Becario QA Backend' },
    company: 'América Móvil / Global Hitss',
    description: { 
      en: 'Backend QA Intern for an América Móvil product. I executed various testing methodologies for the application\'s backend, designing test matrices to ensure robust testing. I implemented a Bash CLI using Postman and Newman to automate smoke tests for the application, reducing testing time by up to 70%.', 
      es: 'Becario QA Backend para un producto de América Móvil. Ejecuté distintas metodologías de pruebas para el backend de la aplicación, diseñando matrices de prueba para asegurar la robustez de las mismas. Implementé un CLI  en Bash usando Postman y Newman para automatizar las pruebas de humo que se realizaban sobre la aplicación, reduciendo el tiempo de éstas  en hasta un 70%.'
    }
  }
];

const sWrap = "relative z-10 max-w-[1100px] w-full mx-auto px-6 md:px-10 shrink-0";

const T = {
  heading: "font-light tracking-tight text-white",
  subheading: "font-mono uppercase tracking-[0.2em] text-zinc-500",
  body: "text-zinc-400 leading-relaxed",
  meta: "text-zinc-600 italic",
  keywords: "font-mono text-zinc-600"
};
---

<Layout title="Work">
  <main class="font-serif min-h-screen bg-[#121212] text-zinc-300 overflow-x-hidden relative flex flex-col justify-between antialiased selection:bg-blue-500/30 selection:text-white">
    <Header />
    
    <section class={`${sWrap} pt-12 md:pt-20 pb-8 md:pb-10 flex-1`}>
      
      <header class="mb-12 border-b border-white/[0.06] pb-8">
        <h1 class="leading-[0.95] tracking-[-0.02em] text-white font-light" style="font-size: clamp(48px, 8vw, 80px);" data-en={t.title.en} data-es={t.title.es}>
          {t.title.en}
        </h1>
      </header>

      <div class="flex flex-col font-mono">
        {workExperience.map((work) => (
          <div class="group py-10 border-b border-white/[0.06] hover:bg-white/[0.02] transition-colors duration-500 px-4 -mx-4 rounded-lg">
            <div class="flex flex-col sm:flex-row sm:items-baseline justify-between mb-4 gap-2">
              <h3 class={`${T.heading} text-[22px] md:text-[24px] group-hover:text-white transition-colors duration-500 font-serif`} data-en={work.title.en} data-es={work.title.es}>
                {work.title.en}
              </h3>
              <span class={`${T.subheading} text-[12px] shrink-0`} data-en={work.year.en} data-es={work.year.es}>
                {work.year.en}
              </span>
            </div>
            
            <p class={`${T.keywords} text-[13px] uppercase tracking-widest mb-6`}>
              {work.company}
            </p>
            
            <p class={`${T.body} text-[16px] md:text-[17px] font-serif max-w-[750px]`} data-en={work.description.en} data-es={work.description.es}>
              {work.description.en}
            </p>
          </div>
        ))}
      </div>
    </section>

    <Footer />
  </main>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap');
    
    .font-serif { 
      font-family: 'Crimson Text', Georgia, 'Times New Roman', serif; 
    }
    
    .font-mono {
      font-family: 'JetBrains Mono', 'Courier New', monospace;
    }
  </style>
</Layout>