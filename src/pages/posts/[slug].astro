---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const postEntries = await getCollection('posts', ({ data }) => data.draft !== true);
  return postEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

const formattedDate = new Date(entry.data.pubDate).toISOString().split('T')[0];
const sWrap = "relative z-10 max-w-[800px] w-full mx-auto px-6 md:px-10 shrink-0";
---

<Layout title={`${entry.data.title} | Luis Angel Moreno`}>
  <main class="font-serif min-h-screen bg-[#121212] text-zinc-300 overflow-x-hidden relative flex flex-col justify-between antialiased selection:bg-blue-500/30 selection:text-white">
    <Header />
    
    <article class={`${sWrap} pt-12 md:pt-20 pb-16 md:pb-24 flex-1`}>
      
      <header class="mb-12 border-b border-white/[0.06] pb-8">
        <div class="flex items-center gap-3 mb-6">
          <time class="text-[14px] font-mono text-zinc-500 tracking-widest">
            {formattedDate}
          </time>
        </div>
        
        <h1 class="leading-[0.95] tracking-[-0.02em] text-white font-light mb-8" style="font-size: clamp(40px, 6vw, 64px);">
          {entry.data.title}
        </h1>
        
        {entry.data.categories && (
          <div class="flex flex-wrap gap-2 font-mono mb-8">
            {entry.data.categories.map((category: string) => (
              <span class="text-[12px] uppercase tracking-[0.2em] text-zinc-500 border border-white/[0.06] px-3 py-1">
                {category}
              </span>
            ))}
          </div>
        )}

        {headings.length > 0 && (
          <nav class="mt-8 border border-white/[0.06] rounded-lg overflow-hidden font-mono">
            <details class="group" open>
              <summary class="cursor-pointer p-5 flex justify-between items-center bg-white/[0.02] hover:bg-white/[0.04] transition-colors list-none">
                <h2 class="text-[13px] uppercase tracking-[0.2em] text-zinc-400 m-0">Índice</h2>
                <span class="text-zinc-500 group-open:rotate-180 transition-transform text-[14px]">▼</span>
              </summary>
              
              <div class="p-5 pt-0 border-t border-white/[0.06] bg-[#121212]">
                <ul class="space-y-3 text-[13px] mt-4">
                  {headings.filter(h => h.depth === 2).map((stage) => {
                    const stageIndex = headings.indexOf(stage);
                    const nextStageIndex = headings.findIndex((h, idx) => idx > stageIndex && h.depth === 2);
                    const subHeadings = headings.filter((h, idx) => 
                      h.depth === 3 && 
                      idx > stageIndex && 
                      (nextStageIndex === -1 ? true : idx < nextStageIndex)
                    );
                    
                    return (
                      <li class="border-b border-white/[0.06] last:border-0 pb-3">
                        <div class="flex justify-between items-center py-1">
                          <a 
                            href={`#${stage.slug}`} 
                            class="text-zinc-400 hover:text-white transition-colors block flex-1"
                          >
                            {stage.text}
                          </a>
                          {subHeadings.length > 0 && (
                            <details class="group/stage ml-4">
                              <summary class="cursor-pointer list-none text-zinc-600 hover:text-zinc-400 transition-colors p-1">
                                <span class="text-[14px]">▼</span>
                              </summary>
                              <ul class="pl-4 py-2 space-y-2 border-l border-white/[0.06] ml-2 mt-2">
                                {subHeadings.map((sub) => (
                                  <li>
                                    <a 
                                      href={`#${sub.slug}`} 
                                      class="text-zinc-500 hover:text-white transition-colors block"
                                    >
                                      {sub.text}
                                    </a>
                                  </li>
                                ))}
                              </ul>
                            </details>
                          )}
                        </div>
                      </li>
                    );
                  })}
                </ul>
              </div>
            </details>
          </nav>
        )}
      </header>
      
      <div class="prose prose-invert max-w-none text-[18px] md:text-[20px] leading-relaxed text-zinc-400
                  prose-headings:font-serif prose-headings:font-light prose-headings:text-white prose-headings:tracking-tight prose-headings:mb-4 prose-headings:mt-8
                  prose-h2:text-3xl prose-h3:text-2xl
                  prose-a:text-blue-300 prose-a:no-underline hover:prose-a:underline hover:prose-a:decoration-blue-300/50 hover:prose-a:text-blue-200 prose-a:transition-all prose-a:duration-300
                  prose-code:font-mono prose-code:text-[14px] prose-code:text-zinc-300 prose-code:bg-white/[0.03] prose-code:px-1.5 prose-code:py-0.5 prose-code:font-normal prose-code:border prose-code:border-white/[0.06] prose-code:rounded-md
                  prose-pre:border prose-pre:border-white/[0.06] prose-pre:bg-[#111] prose-pre:rounded-lg prose-pre:text-[14px]
                  prose-img:border prose-img:border-white/[0.06] prose-img:rounded-lg
                  prose-blockquote:border-l-zinc-600 prose-blockquote:bg-white/[0.02] prose-blockquote:py-2 prose-blockquote:px-5 prose-blockquote:not-italic prose-blockquote:text-zinc-400 prose-blockquote:rounded-r-lg
                  prose-li:marker:text-zinc-600">
        <Content />
      </div>
    </article>

    <Footer />
  </main>
  
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap');
    
    .font-serif { 
      font-family: 'Crimson Text', Georgia, 'Times New Roman', serif; 
    }
    
    .font-mono {
      font-family: 'JetBrains Mono', 'Courier New', monospace;
    }
  </style>
</Layout>