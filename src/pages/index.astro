---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import myPhoto from '../assets/photo.jpeg';
import { getCollection } from 'astro:content';

const featuredSlugs = ['collision-based-computing', 'taxonomy-gol', 'cellular-automata'];

const allPosts = await getCollection('posts');
const posts = featuredSlugs
  .map(slug => allPosts.find(p => p.slug === slug))
  .filter(p => p !== undefined);

const t = {
  sub: { en: "Computer Science Student", es: "Estudiante de Ciencias de la Computación" },
  desc: { en: "3rd year Computer Science student, focused on pragmatic engineering with solid theoretical foundations. In the industry, I have an interest and focus on Backend, Distributed Systems, and AI/Data Systems. In academia, I am currently in a stage of searching for my main focus, but I have dabbled in Cellular Automata Theory, Knowledge Representation, and recently I'm strongly interested in Programming Languages and Formal Methods, this last result of my experience as a QA engineer and my interest in software correctness.", es: "Estudiante de último año en Ciencias de la Computación, entusiasta de lo pragmático cuando emerge de teoría sólida y consistente. En la industria tengo interés y enfoque en Backend, Cómputo Distribuido e IA/Sistemas de Datos. En lo académico, me encuentro en una etapa de búsqueda de mi foco principal, pero he incursionado en Teoría de Autómatas Celulares, Representación del Conocimiento, y recientemente estoy fuertemente interesado en Lenguajes de Programación y Métodos Formales, éste último producto de mi experiencia como QA y mi interés por la correctitud del software."},
  btn: { en: "View Research", es: "Ver Investigación" },
  workTitle: { en: "Featured Public Study", es: "Escritos y Estudio Público destacado" },
  workBtn: { en: "VIEW ALL →", es: "VER TODO →" }
};

const skills = [
  { en: "THEORY", es: "TEORÍA", descEn: "Theorical Computing, Formal Methods, Knowledge Representation.", descEs: "Computación Teórica, Métodos Formales, Representación del Conocimiento.", icon: '<path d="M24 6H10L18 16L10 26H24" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>' },
  { en: "ENGINEERING", es: "INGENIERÍA", descEn: "Backend, Distributed Systems, AI / Data Systems", descEs: "Backend, Sistemas Distribuidos, IA / Datos", icon: '<path d="M11 10L4 16L11 22M21 10L28 16L21 22" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M18 5L14 27" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>' },
  { en: "STACK", es: "STACK", descEn: "JVM (Java/Scala), Python, SQL/NoSQL, Docker, Linux systems.", descEs: "JVM (Java/Scala), Python, SQL/NoSQL, Docker, Linux (Arch).", icon: '<path d="M16 4L28 10.5V21.5L16 28L4 21.5V10.5L16 4Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M4 10.5L16 17M28 10.5L16 17M16 17V28" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>' }
];

const sWrap = "relative z-10 max-w-[1400px] w-full mx-auto px-10 shrink-0";
---

<Layout title="Luis Angel Moreno Delgado">
  <main class="min-h-screen bg-[#191919] text-zinc-300 overflow-x-hidden relative flex flex-col justify-between antialiased">
    <div class="absolute inset-0 opacity-[0.035] noise-bg pointer-events-none"></div>
    <div class="absolute inset-0 grid-overlay pointer-events-none"></div>

    <Header />

    <section class={`${sWrap} pt-12 pb-12`}>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="font-serif leading-none tracking-tight text-white font-light mb-6" style="font-size: clamp(40px, 6vw, 64px);">
            Luis Angel Moreno Delgado
          </h1>
          
          <div class="lg:hidden mb-8">
            <Image 
              src={myPhoto} 
              alt="Portrait" 
              class="w-32 h-32 object-cover" 
              widths={[192, 384]} 
              sizes="(max-width: 768px) 192px, 384px"
              quality={80}
            />
          </div>

          <p class="font-mono text-[14px] uppercase tracking-[0.2em] text-zinc-400 mb-6" data-en={t.sub.en} data-es={t.sub.es}>{t.sub.en}</p>
          <p class="font-mono text-[15px] leading-relaxed text-zinc-300 font-light" data-en={t.desc.en} data-es={t.desc.es}>{t.desc.en}</p>
        </div>

        <div class="hidden lg:flex justify-end">
          <Image 
            src={myPhoto} 
            alt="Portrait" 
            class="w-48 h-48 object-cover" 
            widths={[192, 384]} 
            sizes="(max-width: 768px) 192px, 384px"
            quality={80}
          />
        </div>
      </div>
    </section>

    <div class={sWrap}><div class="h-px bg-white/[0.05]"></div></div>

    <section class={`${sWrap} py-8`}>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {skills.map(s => (
          <div class="border-l border-white/[0.05] pl-6">
            <div class="text-zinc-300 mb-3"><svg width="24" height="24" viewBox="0 0 32 32" fill="none" set:html={s.icon} /></div>
            <h3 class="font-mono text-[13px] tracking-[0.2em] text-white mb-2 font-normal" data-en={s.en} data-es={s.es}>{s.en}</h3>
            <p class="font-mono text-zinc-400 leading-snug text-[14px] font-light pr-4" data-en={s.descEn} data-es={s.descEs}>{s.descEn}</p>
          </div>
        ))}
      </div>
    </section>

    <div class={sWrap}><div class="h-px bg-white/[0.05]"></div></div>

    <section class={`${sWrap} py-8 flex-1 flex flex-col justify-center`}>
  <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-6 font-mono gap-4">
    <h2 class="text-[13px] uppercase tracking-[0.2em] text-zinc-400 font-normal" data-en={t.workTitle.en} data-es={t.workTitle.es}>{t.workTitle.en}</h2>
    <a href="/posts/" class="text-[12px] uppercase tracking-[0.2em] text-zinc-400 hover:text-white transition-colors duration-500" data-en={t.workBtn.en} data-es={t.workBtn.es}>{t.workBtn.en}</a>
  </div>

  <p
    class="font-mono text-[11px] text-zinc-500 font-light mb-6"
    data-en="None of the posts presented here were written with AI."
    data-es="Ninguno de los escritos presentados aquí han sido escritos con IA."
  >
    None of the posts presented here were created in collaboration with AI.
  </p>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-5 font-mono">
    {posts.map(p => (
      <a href={`/posts/${p.slug}`} class="border border-white/[0.05] p-5 hover:border-white/[0.15] transition-colors duration-500 bg-[#171616] hover:-translate-y-1 block relative overflow-hidden" style="min-height: 160px;">
        <h3 class="text-white text-[14px] tracking-wide font-normal mb-2">{p.data.title}</h3>
        <p class="text-zinc-400 leading-snug text-[14px] font-light">{p.data.description}</p>
      </a>
    ))}
  </div>
</section>
    <Footer />
  </main>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@300;400;500&display=swap');
    .font-serif { font-family: 'Crimson Text', serif; }
    .font-mono { font-family: 'JetBrains Mono', monospace; }
    .noise-bg { background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E"); }
    .grid-overlay { background-size: 80px 80px; background-image: linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px); }
  </style>
</Layout>