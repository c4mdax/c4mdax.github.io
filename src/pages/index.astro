---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import heroPhoto from '../assets/photo.jpeg';

// Importación de archivos PDF
import cvFileES from '../assets/CV_2026Q2_ES.pdf';
import cvFileEN from '../assets/CV_2026Q2_EN.pdf';

const translations = {
    name: { en: "Luis Angel Moreno Delgado", es: "Luis Angel Moreno Delgado" },
    heroDesc1: { en: "Computer Science Student", es: "Estudiante de Ciencias de la Computación" },
    heroDesc2: { en: "&", es: "y" },
    heroDesc3: { en: "Backend · ML", es: "Backend · ML" },
    viewProjects: { en: "Projects", es: "Proyectos" },
    getInTouch: { en: "Contact", es: "Contacto" },
    roleTitle: { en: "", es: "" },
    downloadCv: { en: "Download CV - English version", es: "Descargar CV - versión en Español" },
    aboutTitle: { en: "About", es: "Sobre Mí" },
    meLine1: { en: "Computer Science student @ UNAM", es: "Estudiante de Ciencias de la Computación @ UNAM" },
    meLine2: { en: "In the industry, enthusiastic about Backend Architecture & ML", es: "En la industria, entusiasta de la Arquitectura Backend y el Machine Learning" },
    meLine3: { en: "In academia, interested about Automata Theory & Discrete Dynamical Systems", es: "En la academia, interesado por la Teoría de Autómatas y los Sistemas Dinámicos Discretos" },
    resourcesTitle: { en: "Resources I'm studying", es: "Recursos que estoy estudiando" },
    industryTitle: { en: "Industry", es: "Industria" },
    academiaTitle: { en: "Academia", es: "Academia" },
    madeByMe: { en: "(made by me)", es: "(hecho por mí)" },
    tech: { en: "Tech Stack", es: "Stack Tecnológico" }
};

const techStack = ['Java', 'Spring', 'Python', 'Scala', 'SQL', 'Docker', 'ML / AI', 'LLMs', 'Data Eng'];
---

<Layout title={`Luis Angel Moreno Delgado`}>
    <Header />
    
    <main class="min-h-screen px-4 sm:px-6 md:px-8 flex flex-col justify-center bg-white dark:bg-[#050505] transition-colors duration-500 selection:bg-[#e11d48]/20 selection:text-[#e11d48] dark:selection:text-white relative overflow-hidden">
        
        <!-- INCREASED OPACITY HERE -->
        <canvas id="automataCanvas" class="absolute inset-0 w-full h-full opacity-15 dark:opacity-10 pointer-events-none z-0"></canvas>

        <!-- HERO -->
        <section class="max-w-5xl mx-auto w-full pt-40 sm:pt-56 pb-24 sm:pb-32 fade-in relative z-10">
            <div class="flex flex-col lg:flex-row items-center lg:items-start gap-14 sm:gap-20 text-center lg:text-left">
                
                <!-- Foto -->
                <div class="flex-shrink-0 relative">
                    <div class="absolute -inset-px rounded-full border border-zinc-200 dark:border-white/8"></div>
                    <div class="w-44 h-44 sm:w-56 sm:h-56 rounded-full overflow-hidden border border-zinc-300 dark:border-white/10 shadow-lg relative z-10">
                        <img 
                            src={heroPhoto.src} 
                            alt="Luis Angel Moreno Delgado" 
                            class="w-full h-full object-cover object-top grayscale contrast-105 brightness-95 scale-105"
                            onerror="this.style.display='none';" 
                            loading="eager"
                            fetchpriority="high"
                        />
                    </div>
                    <div class="absolute bottom-1.5 right-1.5 flex items-center gap-1.5 z-20">
                        <span class="w-2 h-2 rounded-full bg-[#e11d48] shadow-sm shadow-[#e11d48]/60"></span>
                    </div>
                </div>

                <!-- Texto -->
                <div class="flex flex-col items-center lg:items-start max-w-2xl mt-6 lg:mt-2">
                    <p class="text-[10px] font-mono uppercase tracking-[0.35em] text-zinc-400 dark:text-zinc-600 mb-6"
                       data-en={translations.roleTitle.en} data-es={translations.roleTitle.es}>
                        {translations.roleTitle.es}
                    </p>
                    
                    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-zinc-900 dark:text-white mb-6 tracking-tight leading-[1.08]"
                        data-en={translations.name.en} data-es={translations.name.es}>
                        {translations.name.es}
                    </h1>

                    <p class="text-sm sm:text-base text-zinc-500 dark:text-zinc-500 mb-12 leading-relaxed font-light max-w-md">
                        <span data-en={translations.heroDesc1.en} data-es={translations.heroDesc1.es}>{translations.heroDesc1.es}</span><span class="text-[#e11d48] mx-2 font-serif italic" data-en={translations.heroDesc2.en} data-es={translations.heroDesc2.es}>{translations.heroDesc2.es}</span><span data-en={translations.heroDesc3.en} data-es={translations.heroDesc3.es}>{translations.heroDesc3.es}</span>
                    </p>

                    <!-- CTAs -->
                    <div class="flex flex-wrap gap-4 justify-center lg:justify-start w-full font-mono">
                        <a href="/projects"
                           class="relative px-7 py-2.5 text-[11px] tracking-[0.18em] uppercase text-white dark:text-black bg-zinc-900 dark:bg-white hover:bg-[#e11d48] dark:hover:bg-[#e11d48] dark:hover:text-white transition-colors duration-300"
                           data-en={translations.viewProjects.en} data-es={translations.viewProjects.es}>
                            {translations.viewProjects.es}
                        </a>
                        <a href="/contact"
                           class="relative px-7 py-2.5 text-[11px] tracking-[0.18em] uppercase text-zinc-700 dark:text-zinc-300 border border-zinc-300 dark:border-white/15 hover:border-[#e11d48] hover:text-[#e11d48] dark:hover:text-[#e11d48] dark:hover:border-[#e11d48] transition-colors duration-300"
                           data-en={translations.getInTouch.en} data-es={translations.getInTouch.es}>
                            {translations.getInTouch.es}
                        </a>
                    </div>
                    
                    <!-- CV Download -->
                    <div class="mt-14 flex w-full justify-center lg:justify-start">
                        <a 
                            href={cvFileES}
                            download="CV_LuisAngelMoreno_ES.pdf"
                            data-cv-en={cvFileEN}
                            data-cv-es={cvFileES}
                            data-filename-en="CV_LuisAngelMoreno_EN.pdf"
                            data-filename-es="CV_LuisAngelMoreno_ES.pdf"
                            id="cv-download-link"
                            class="group flex items-center gap-4 text-[10px] uppercase tracking-[0.3em] text-zinc-400 hover:text-[#e11d48] dark:text-zinc-600 dark:hover:text-[#e11d48] transition-colors duration-400"
                        >
                            <span class="w-6 h-px bg-current transition-all duration-500 group-hover:w-10"></span>
                            <span data-en={translations.downloadCv.en} data-es={translations.downloadCv.es}>{translations.downloadCv.es}</span>
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <div class="w-full max-w-5xl mx-auto h-px bg-zinc-100 dark:bg-white/5 my-2 relative z-10"></div>

        <!-- ABOUT -->
        <section class="max-w-5xl mx-auto py-28 fade-in w-full relative z-10">
            <h2 class="text-[10px] font-mono uppercase tracking-[0.35em] text-zinc-400 dark:text-zinc-600 mb-14 text-center md:text-left"
                data-en={translations.aboutTitle.en} data-es={translations.aboutTitle.es}>
                {translations.aboutTitle.es}
            </h2>
            
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
                <div class="md:col-span-5 p-8 sm:p-10 bg-zinc-50/60 dark:bg-[#080808]/60 border border-zinc-150 dark:border-white/[0.04] hover:border-zinc-300 dark:hover:border-white/10 transition-colors duration-500">
                    <ul class="space-y-9 text-zinc-700 dark:text-zinc-400 text-sm font-light leading-relaxed">
                        <li class="flex items-start gap-5">
                            <span class="font-mono text-[10px] mt-0.5 text-[#e11d48] shrink-0">01</span>
                            <span class="text-zinc-800 dark:text-zinc-300 text-sm">
                                <span data-en={translations.meLine1.en} data-es={translations.meLine1.es}>{translations.meLine1.es}</span> 
                                (<a href="https://www.fciencias.unam.mx/" target="_blank" rel="noopener noreferrer"
                                    class="text-zinc-500 dark:text-zinc-500 hover:text-[#e11d48] border-b border-transparent hover:border-[#e11d48] transition-all duration-300">FC UNAM</a>)
                            </span>
                        </li>
                        <li class="flex items-start gap-5">
                            <span class="font-mono text-[10px] mt-0.5 text-[#e11d48] shrink-0">02</span>
                            <span class="text-zinc-800 dark:text-zinc-300 text-sm"
                                  data-en={translations.meLine2.en} data-es={translations.meLine2.es}>{translations.meLine2.es}</span>
                        </li>
                        <li class="flex items-start gap-5">
                            <span class="font-mono text-[10px] mt-0.5 text-[#e11d48] shrink-0">03</span>
                            <span class="text-zinc-800 dark:text-zinc-300 text-sm"
                                  data-en={translations.meLine3.en} data-es={translations.meLine3.es}>{translations.meLine3.es}</span>
                        </li>
                    </ul>
                </div>

                <div class="md:col-span-7 p-8 sm:p-10 bg-zinc-50/60 dark:bg-[#080808]/60 border border-zinc-150 dark:border-white/[0.04] hover:border-zinc-300 dark:hover:border-white/10 transition-colors duration-500 flex flex-col justify-center">
                    <h3 class="text-[11px] font-mono font-medium text-zinc-900 dark:text-white mb-10 flex items-center gap-3 uppercase tracking-[0.2em]">
                        <div class="w-1 h-1 bg-[#e11d48]"></div>
                        <span data-en={translations.resourcesTitle.en} data-es={translations.resourcesTitle.es}>{translations.resourcesTitle.es}</span>
                    </h3>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">
                        <div>
                            <h4 class="text-[9px] font-mono uppercase tracking-[0.25em] text-[#e11d48] mb-6"
                                data-en={translations.industryTitle.en} data-es={translations.industryTitle.es}>{translations.industryTitle.es}</h4>
                            <ul class="space-y-5 text-sm text-zinc-600 dark:text-zinc-500 font-light">
                                <li>
                                    <a href="#" class="flex flex-col gap-0.5 group/item">
                                        <span class="text-zinc-800 dark:text-zinc-300 text-[13px] group-hover/item:text-[#e11d48] transition-colors duration-300">Effective Java</span>
                                        <span class="text-[9px] font-mono tracking-widest uppercase text-zinc-400 dark:text-zinc-600">Joshua Bloch</span>
                                    </a>
                                </li>
                                <li>
                                    <a href="#" class="flex flex-col gap-0.5 group/item">
                                        <span class="text-zinc-800 dark:text-zinc-300 text-[13px] group-hover/item:text-[#e11d48] transition-colors duration-300">ML Roadmap</span>
                                        <span class="text-[9px] font-mono tracking-widest uppercase text-[#e11d48]/70"
                                              data-en={translations.madeByMe.en} data-es={translations.madeByMe.es}>{translations.madeByMe.es}</span>
                                    </a>
                                </li>
                            </ul>
                        </div>
                        <div>
                            <h4 class="text-[9px] font-mono uppercase tracking-[0.25em] text-[#e11d48] mb-6"
                                data-en={translations.academiaTitle.en} data-es={translations.academiaTitle.es}>{translations.academiaTitle.es}</h4>
                            <ul class="space-y-5 text-sm text-zinc-600 dark:text-zinc-500 font-light">
                                <li>
                                    <a href="#" class="flex flex-col gap-0.5 group/item">
                                        <span class="text-zinc-800 dark:text-zinc-300 text-[13px] group-hover/item:text-[#e11d48] transition-colors duration-300">A New Kind of Science</span>
                                        <span class="text-[9px] font-mono tracking-widest uppercase text-zinc-400 dark:text-zinc-600">Stephen Wolfram</span>
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- TECH STACK -->
        <section class="max-w-5xl mx-auto pt-4 pb-36 fade-in w-full relative z-10">
            <h2 class="text-[9px] font-mono uppercase tracking-[0.4em] text-zinc-400 dark:text-zinc-600 mb-10 text-center md:text-left"
                data-en={translations.tech.en} data-es={translations.tech.es}>{translations.tech.es}</h2>
            
            <ul class="flex flex-wrap gap-2 list-none p-0 m-0">
                {techStack.map(tech => (
                    <li>
                        <span class="px-4 py-2 text-[10px] font-mono uppercase tracking-[0.15em] border border-zinc-200 dark:border-white/[0.06] text-zinc-500 dark:text-zinc-500 hover:border-[#e11d48] hover:text-[#e11d48] transition-colors duration-300 cursor-default block">
                            {tech}
                        </span>
                    </li>
                ))}
            </ul>
        </section>

    </main>

    <Footer />

    <style>
        .fade-in {
            opacity: 0;
            transform: translateY(16px);
            transition: opacity 0.7s ease, transform 0.7s ease;
        }
        .fade-in.visible {
            opacity: 1;
            transform: translateY(0);
        }
    </style>

    <script>
        /* ─── Automata de Conway ─── */
        function startAutomata() {
            const canvas = document.getElementById('automataCanvas') as HTMLCanvasElement;
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            if (!ctx) return;

            let cols: number, rows: number;
            const cellSize = 12;
            let grid: number[][];

            function init() {
                const rect = canvas.getBoundingClientRect();
                cols = Math.floor(rect.width / cellSize);
                rows = Math.floor(rect.height / cellSize);
                canvas.width  = cols * cellSize;
                canvas.height = rows * cellSize;
                grid = Array.from({ length: cols }, () =>
                    Array.from({ length: rows }, () => (Math.random() > 0.88 ? 1 : 0))
                );
            }

            function update() {
                const next = grid.map(line => [...line]);
                for (let i = 0; i < cols; i++) {
                    for (let j = 0; j < rows; j++) {
                        let n = 0;
                        for (let x = -1; x <= 1; x++) {
                            for (let y = -1; y <= 1; y++) {
                                if (x === 0 && y === 0) continue;
                                n += grid[(i + x + cols) % cols][(j + y + rows) % rows];
                            }
                        }
                        if (grid[i][j] === 1 && (n < 2 || n > 3)) next[i][j] = 0;
                        else if (grid[i][j] === 0 && n === 3) next[i][j] = 1;
                    }
                }
                grid = next;
            }

            function draw() {
                ctx!.clearRect(0, 0, canvas.width, canvas.height);
                ctx!.fillStyle = '#e11d48';
                for (let i = 0; i < cols; i++) {
                    for (let j = 0; j < rows; j++) {
                        if (grid[i][j] === 1) {
                            ctx!.fillRect(i * cellSize + 1, j * cellSize + 1, cellSize - 2, cellSize - 2);
                        }
                    }
                }
            }

            let lastTime = 0;
            function animate(time: number) {
                if (time - lastTime > 220) {
                    update();
                    draw();
                    lastTime = time;
                }
                requestAnimationFrame(animate);
            }

            // Performance: Debounce window resize to avoid excessive recalcs
            let resizeTimeout: ReturnType<typeof setTimeout>;
            window.addEventListener('resize', () => {
                clearTimeout(resizeTimeout);
                resizeTimeout = setTimeout(() => {
                    init();
                    draw();
                }, 150);
            });
            
            init();
            animate(0);
        }

        /* ─── CV Sync Logic ─── */
        function syncCvLink() {
            const link = document.getElementById('cv-download-link') as HTMLAnchorElement | null;
            if (!link) return;

            const lang = document.documentElement.getAttribute('data-lang') || 
                         document.documentElement.lang || 
                         'es';
            
            if (lang.toLowerCase().includes('en')) {
                link.href = link.getAttribute('data-cv-en') || '';
                link.download = link.getAttribute('data-filename-en') || 'CV_LuisAngelMoreno_EN.pdf';
            } else {
                link.href = link.getAttribute('data-cv-es') || '';
                link.download = link.getAttribute('data-filename-es') || 'CV_LuisAngelMoreno_ES.pdf';
            }
        }

        /* ─── Scroll Observer ─── */
        function initObserver() {
            const observer = new IntersectionObserver(
                (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
                { threshold: 0.1 }
            );
            document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
        }

        /* ─── Init ─── */
        document.addEventListener('DOMContentLoaded', () => {
            startAutomata();
            initObserver();
            syncCvLink();

            document.addEventListener('languageChanged', () => {
                setTimeout(syncCvLink, 50);
            });
            
            const htmlObserver = new MutationObserver(() => {
                syncCvLink();
            });

            htmlObserver.observe(document.documentElement, { 
                attributes: true, 
                attributeFilter: ['lang', 'data-lang'] 
            });
        });
    </script>
</Layout>