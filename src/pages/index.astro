---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import heroPhoto from '../assets/photo.jpeg';

import cvFileES from '../assets/CV_2026Q2_ES.pdf';
import cvFileEN from '../assets/CV_2026Q2_EN.pdf';

const translations = {
    name:          { en: "Luis Angel Moreno Delgado", es: "Luis Angel Moreno Delgado" },
    heroDesc:      { en: "Computer Science",           es: "Ciencias de la Computación" },
    badge1:        { en: "Backend",                    es: "Backend" },
    badge2:        { en: "AI",                         es: "IA" },
    badge3:        { en: "Data Engineering",           es: "Ingeniería de Datos" },
    viewProjects:  { en: "Projects",                   es: "Proyectos" },
    getInTouch:    { en: "Contact",                    es: "Contacto" },
    roleTitle:     { en: "",                           es: "" },
    downloadCv:    { en: "Download CV - English version", es: "Descargar CV - versión en Español" },
    aboutTitle:    { en: "About",                      es: "Sobre Mí" },
    meLine1:       { en: "Computer Science",           es: "Ciencias de la Computación" },
    meLine2:       { en: "In the industry, enthusiastic about Backend Architecture & ML",
                     es: "En la industria, entusiasta de la Arquitectura Backend y el Machine Learning" },
    meLine3:       { en: "In academia, interested about Automata Theory (emphasis on Cellular Automata) & Discrete Dynamical Systems",
                     es: "En la academia, interesado por la Teoría de Autómatas (énfasis en Autómatas Celulares) y los Sistemas Dinámicos Discretos" },
    resourcesTitle:{ en: "Resources I'm studying",    es: "Recursos que estoy estudiando" },
    industryTitle: { en: "Industry",                   es: "Industria" },
    academiaTitle: { en: "Academia",                   es: "Academia" },
    tech:          { en: "Tech Stack",                 es: "Stack Tecnológico" },
} as const;

const techStack = [
    'Java', 'Python', 'Scala',
    'Spring', 'FastAPI',
    'SQL', 'PostgreSQL', 'Spark',
    'PyTorch', 'scikit-learn',
    'Docker', 'Linux', 'Git',
] as const;
---

<Layout title="Luis Angel Moreno Delgado">
    <Header />

    <div class="fixed inset-0 pointer-events-none z-50 bg-[radial-gradient(circle_at_center,transparent_0%,rgba(0,0,0,0.85)_100%)]"></div>
    <div class="fixed inset-0 pointer-events-none z-40 opacity-[0.03] mix-blend-overlay noise-bg"></div>

    <main class="min-h-screen px-4 sm:px-6 md:px-8 flex flex-col justify-center bg-black transition-colors duration-1000 selection:bg-[#e11d48]/30 selection:text-white relative overflow-hidden text-zinc-300">

        <canvas id="automataCanvas" class="absolute inset-0 w-full h-full opacity-30 pointer-events-none z-0" style="will-change: transform;"></canvas>

        <section class="max-w-5xl mx-auto w-full pt-40 sm:pt-56 pb-24 sm:pb-32 fade-in relative z-10">
            <div class="flex flex-col lg:flex-row items-center lg:items-start gap-14 sm:gap-20 text-center lg:text-left">

                <div class="flex-shrink-0 relative group">
                    <div class="absolute -inset-4 rounded-full bg-[#e11d48] opacity-20 blur-2xl group-hover:opacity-40 transition-opacity duration-1000"></div>
                    <div class="absolute -inset-px rounded-full border border-zinc-800"></div>
                    <div class="w-44 h-44 sm:w-56 sm:h-56 rounded-full overflow-hidden border border-white/5 shadow-[0_0_40px_rgba(0,0,0,0.8)] relative z-10">
                        <Image
                            src={heroPhoto}
                            alt="Luis Angel Moreno Delgado"
                            class="w-full h-full object-cover object-top grayscale contrast-125 brightness-105 scale-105"
                            loading="eager"
                            fetchpriority="high"
                            decoding="sync"
                        />
                    </div>
                    <div class="absolute bottom-2 right-2 flex items-center gap-1.5 z-20">
                        <span class="w-2.5 h-2.5 rounded-full bg-[#e11d48] shadow-[0_0_10px_#e11d48] animate-pulse"></span>
                    </div>
                </div>

                <div class="flex flex-col items-center lg:items-start max-w-2xl mt-6 lg:mt-2">
                    <p class="text-xs font-mono uppercase tracking-[0.4em] text-zinc-500 mb-6"
                       data-en={translations.roleTitle.en} data-es={translations.roleTitle.es}>
                        {translations.roleTitle.es}
                    </p>

                    <h1 class="text-4xl sm:text-5xl md:text-7xl font-extrabold text-white mb-4 tracking-tighter leading-[1.05] drop-shadow-2xl"
                        data-en={translations.name.en} data-es={translations.name.es}>
                        {translations.name.es}
                    </h1>

                    <div class="mb-12">
                        <p class="text-lg sm:text-xl text-zinc-400 mb-6 font-light tracking-wide">
                            <span data-en={translations.heroDesc.en} data-es={translations.heroDesc.es}>{translations.heroDesc.es}</span>
                        </p>

                        <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
                            {[translations.badge1, translations.badge2, translations.badge3].map(b => (
                                <span class="px-5 py-2 rounded-sm text-xs font-mono uppercase tracking-[0.2em] font-bold border border-[#e11d48]/20 bg-[#e11d48]/5 text-[#e11d48] shadow-[0_0_15px_rgba(225,29,72,0.1)] transition-all hover:bg-[#e11d48]/10 hover:shadow-[0_0_25px_rgba(225,29,72,0.2)] cursor-default"
                                    data-en={b.en} data-es={b.es}>
                                    {b.es}
                                </span>
                            ))}
                        </div>
                    </div>

                    <div class="flex flex-wrap gap-5 justify-center lg:justify-start w-full font-mono">
                        <a href="/projects"
                           class="relative px-8 py-3 text-xs tracking-[0.25em] uppercase text-black bg-white hover:bg-[#e11d48] hover:text-white transition-colors duration-500 shadow-[0_0_20px_rgba(255,255,255,0.1)] hover:shadow-[0_0_30px_rgba(225,29,72,0.3)]"
                           data-en={translations.viewProjects.en} data-es={translations.viewProjects.es}>
                            {translations.viewProjects.es}
                        </a>
                        <a href="/contact"
                           class="relative px-8 py-3 text-xs tracking-[0.25em] uppercase text-zinc-400 border border-zinc-700 hover:border-[#e11d48] hover:text-[#e11d48] transition-colors duration-500"
                           data-en={translations.getInTouch.en} data-es={translations.getInTouch.es}>
                            {translations.getInTouch.es}
                        </a>
                    </div>

                    <div class="mt-16 flex w-full justify-center lg:justify-start">
                        <a
                            href={cvFileES}
                            download="CV_LuisAngelMoreno_ES.pdf"
                            data-cv-en={cvFileEN}
                            data-cv-es={cvFileES}
                            data-filename-en="CV_LuisAngelMoreno_EN.pdf"
                            data-filename-es="CV_LuisAngelMoreno_ES.pdf"
                            id="cv-download-link"
                            class="group flex items-center gap-5 text-xs uppercase tracking-[0.4em] text-zinc-500 hover:text-[#e11d48] transition-colors duration-700"
                        >
                            <span class="w-8 h-px bg-current transition-all duration-700 group-hover:w-14"></span>
                            <span data-en={translations.downloadCv.en} data-es={translations.downloadCv.es}>{translations.downloadCv.es}</span>
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <div class="w-full max-w-5xl mx-auto h-px bg-gradient-to-r from-transparent via-zinc-800 to-transparent my-4 relative z-10"></div>

        <section class="max-w-5xl mx-auto py-28 fade-in w-full relative z-10">
            <h2 class="text-sm font-mono uppercase tracking-[0.4em] text-zinc-500 mb-16 text-center md:text-left"
                data-en={translations.aboutTitle.en} data-es={translations.aboutTitle.es}>
                {translations.aboutTitle.es}
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
                <div class="md:col-span-5 p-8 sm:p-10 bg-[#030303]/80 border border-white/[0.02] backdrop-blur-sm transition-colors duration-700 relative overflow-hidden">
                    <ul class="space-y-10 text-zinc-400 text-base font-light leading-relaxed">
                        <li class="flex items-start gap-6">
                            <span class="font-mono text-xs mt-1 text-[#e11d48] opacity-70">01</span>
                            <span class="text-zinc-300">
                                <span data-en={translations.meLine1.en} data-es={translations.meLine1.es}>{translations.meLine1.es}</span>
                                (<a href="https://www.fciencias.unam.mx/" target="_blank" rel="noopener noreferrer"
                                    class="text-zinc-500 hover:text-[#e11d48] border-b border-transparent hover:border-[#e11d48] transition-all duration-500">Universidad Nacional Autónoma de México</a>)
                            </span>
                        </li>
                        <li class="flex items-start gap-6">
                            <span class="font-mono text-xs mt-1 text-[#e11d48] opacity-70">02</span>
                            <span class="text-zinc-300" data-en={translations.meLine2.en} data-es={translations.meLine2.es}>{translations.meLine2.es}</span>
                        </li>
                        <li class="flex items-start gap-6">
                            <span class="font-mono text-xs mt-1 text-[#e11d48] opacity-70">03</span>
                            <span class="text-zinc-300" data-en={translations.meLine3.en} data-es={translations.meLine3.es}>{translations.meLine3.es}</span>
                        </li>
                    </ul>
                </div>

                <div class="md:col-span-7 p-8 sm:p-10 bg-[#030303]/80 border border-white/[0.02] backdrop-blur-sm transition-colors duration-700 flex flex-col justify-center relative overflow-hidden">
                    <h3 class="text-sm font-mono text-white mb-12 flex items-center gap-4 uppercase tracking-[0.3em]">
                        <div class="w-1.5 h-1.5 bg-[#e11d48] rotate-45"></div>
                        <span data-en={translations.resourcesTitle.en} data-es={translations.resourcesTitle.es}>{translations.resourcesTitle.es}</span>
                    </h3>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-12">
                        <div>
                            <h4 class="text-xs font-mono uppercase tracking-[0.3em] text-[#e11d48] mb-8 opacity-80"
                                data-en={translations.industryTitle.en} data-es={translations.industryTitle.es}>{translations.industryTitle.es}</h4>
                            <ul class="space-y-6 text-base text-zinc-500 font-light">
                                <li><a href="#" class="flex flex-col gap-1.5 group/item">
                                    <span class="text-zinc-300 text-base group-hover/item:text-[#e11d48] transition-colors duration-500">Effective Java</span>
                                    <span class="text-xs font-mono tracking-[0.2em] uppercase text-zinc-600">Joshua Bloch</span>
                                </a></li>
                                <li><a href="#" class="flex flex-col gap-1.5 group/item">
                                    <span class="text-zinc-300 text-base group-hover/item:text-[#e11d48] transition-colors duration-500">Spring Start Here</span>
                                    <span class="text-xs font-mono tracking-[0.2em] uppercase text-zinc-600">Laurentiu Spilca</span>
                                </a></li>
                                <li><a href="#" class="flex flex-col gap-1.5 group/item">
                                    <span class="text-zinc-300 text-base group-hover/item:text-[#e11d48] transition-colors duration-500">Programming in Scala</span>
                                    <span class="text-xs font-mono tracking-[0.2em] uppercase text-zinc-600">Martin Odersky, et al.</span>
                                </a></li>
                            </ul>
                        </div>
                        <div>
                            <h4 class="text-xs font-mono uppercase tracking-[0.3em] text-[#e11d48] mb-8 opacity-80"
                                data-en={translations.academiaTitle.en} data-es={translations.academiaTitle.es}>{translations.academiaTitle.es}</h4>
                            <ul class="space-y-6 text-base text-zinc-500 font-light">
                                <li><a href="#" class="flex flex-col gap-1.5 group/item">
                                    <span class="text-zinc-300 text-base group-hover/item:text-[#e11d48] transition-colors duration-500">A New Kind of Science</span>
                                    <span class="text-xs font-mono tracking-[0.2em] uppercase text-zinc-600">Stephen Wolfram</span>
                                </a></li>
                                <li><a href="#" class="flex flex-col gap-1.5 group/item">
                                    <span class="text-zinc-300 text-base group-hover/item:text-[#e11d48] transition-colors duration-500">Cellular Automata and Complexity</span>
                                    <span class="text-xs font-mono tracking-[0.2em] uppercase text-zinc-600">Stephen Wolfram</span>
                                </a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="max-w-5xl mx-auto pt-8 pb-40 fade-in w-full relative z-10">
            <h2 class="text-sm font-mono uppercase tracking-[0.5em] text-zinc-600 mb-12 text-center md:text-left"
                data-en={translations.tech.en} data-es={translations.tech.es}>{translations.tech.es}</h2>

            <div class="flex flex-wrap gap-3">
                {techStack.map(tech => (
                    <span class="px-5 py-2.5 text-xs font-mono uppercase tracking-[0.2em] border border-zinc-800 bg-[#030303] text-zinc-400 hover:border-[#e11d48] hover:text-white transition-all duration-500 cursor-default shadow-lg">
                        {tech}
                    </span>
                ))}
            </div>
        </section>

    </main>

    <Footer />

    <style>
        .fade-in {
            opacity: 0;
            transform: translateY(24px);
            transition: opacity 0.8s cubic-bezier(0.2, 0.8, 0.2, 1),
                        transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
        }
        .fade-in.visible {
            opacity: 1;
            transform: translateY(0);
        }
        .noise-bg {
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        }
    </style>

    <script>
        function startAutomata() {
            const canvas = document.getElementById('automataCanvas') as HTMLCanvasElement;
            if (!canvas) return;
            const ctx = canvas.getContext('2d', { alpha: false });
            if (!ctx) return;

            const cellSize = 16;
            let cols: number, rows: number;
            let gridA: Uint8Array, gridB: Uint8Array;
            let isGridA = true;
            let rafId: number;

            function handleVisibility() {
                if (document.hidden) {
                    cancelAnimationFrame(rafId);
                } else {
                    lastTime = 0;
                    rafId = requestAnimationFrame(animate);
                }
            }
            document.addEventListener('visibilitychange', handleVisibility);

            function init() {
                const rect = canvas.getBoundingClientRect();
                cols = Math.floor(rect.width  / cellSize);
                rows = Math.floor(rect.height / cellSize);
                canvas.width  = cols * cellSize;
                canvas.height = rows * cellSize;

                const size = cols * rows;
                gridA = new Uint8Array(size);
                gridB = new Uint8Array(size);
                for (let i = 0; i < size; i++) {
                    gridA[i] = Math.random() > 0.90 ? 1 : 0;
                }
                isGridA = true;
            }

            function update() {
                const current = isGridA ? gridA : gridB;
                const next    = isGridA ? gridB : gridA;

                for (let y = 0; y < rows; y++) {
                    for (let x = 0; x < cols; x++) {
                        const idx = y * cols + x;
                        let n = 0;
                        for (let dy = -1; dy <= 1; dy++) {
                            for (let dx = -1; dx <= 1; dx++) {
                                if (dx === 0 && dy === 0) continue;
                                const nx = (x + dx + cols) % cols;
                                const ny = (y + dy + rows) % rows;
                                n += current[ny * cols + nx];
                            }
                        }
                        if      (current[idx] === 1 && (n < 2 || n > 3)) next[idx] = 0;
                        else if (current[idx] === 0 && n === 3)           next[idx] = 1;
                        else                                               next[idx] = current[idx];
                    }
                }
                isGridA = !isGridA;
            }

            function draw() {
                ctx!.clearRect(0, 0, canvas.width, canvas.height);
                ctx!.fillStyle = '#9f1239';
                ctx!.beginPath();
                const current = isGridA ? gridA : gridB;
                for (let y = 0; y < rows; y++) {
                    for (let x = 0; x < cols; x++) {
                        if (current[y * cols + x] === 1) {
                            ctx!.rect(x * cellSize + 1, y * cellSize + 1, cellSize - 2, cellSize - 2);
                        }
                    }
                }
                ctx!.fill();
            }

            let lastTime = 0;
            const FRAME_INTERVAL = 300;

            function animate(time: number) {
                rafId = requestAnimationFrame(animate);
                if (time - lastTime < FRAME_INTERVAL) return;
                update();
                draw();
                lastTime = time;
            }

            let resizeTimeout: number;
            const ro = new ResizeObserver(() => {
                clearTimeout(resizeTimeout);
                resizeTimeout = window.setTimeout(() => { init(); draw(); }, 200);
            });
            ro.observe(canvas);

            init();
            rafId = requestAnimationFrame(animate);
        }

        function syncCvLink() {
            const link = document.getElementById('cv-download-link') as HTMLAnchorElement | null;
            if (!link) return;
            const lang = (document.documentElement.getAttribute('data-lang') || document.documentElement.lang || 'es').toLowerCase();
            if (lang.includes('en')) {
                link.href     = link.getAttribute('data-cv-en')       || '';
                link.download = link.getAttribute('data-filename-en') || 'CV_LuisAngelMoreno_EN.pdf';
            } else {
                link.href     = link.getAttribute('data-cv-es')       || '';
                link.download = link.getAttribute('data-filename-es') || 'CV_LuisAngelMoreno_ES.pdf';
            }
        }

        function initObserver() {
            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach(e => {
                        if (e.isIntersecting) {
                            e.target.classList.add('visible');
                            observer.unobserve(e.target);
                        }
                    });
                },
                { threshold: 0.15 }
            );
            document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
        }

        document.addEventListener('DOMContentLoaded', () => {
            startAutomata();
            initObserver();
            syncCvLink();

            document.addEventListener('languageChanged', () => setTimeout(syncCvLink, 50));

            const htmlObserver = new MutationObserver(syncCvLink);
            htmlObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['lang', 'data-lang'] });

            document.addEventListener('astro:before-swap', () => htmlObserver.disconnect(), { once: true });
        });
    </script>
</Layout>