---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import heroPhoto from '../assets/photo.jpeg';
import cvFile from '../assets/CV_2026_Q2.pdf';

const translations = {
    name: { 
        en: "Luis Angel Moreno Delgado", 
        es: "Luis Angel Moreno Delgado" 
    },
    heroDesc1: {
        en: "Computer Science Student",
        es: "Estudiante de Ciencias de la Computación"
    },
    heroDesc2: {
        en: "&",
        es: "y"
    },
    heroDesc3: {
        en: "Backend - ML enthusiast",
        es: "Entusiasta de la Arquitectura Backend y del Aprendizaje Automático"
    },
    heroDesc4: {
        en: "",
        es: ""
    },
    viewProjects: { 
        en: "Projects", 
        es: "Proyectos" 
    },
    getInTouch: { 
        en: "Contact", 
        es: "Contacto" 
    },
    roleTitle: {
        en: "Software Developer",
        es: "Desarrollador de Software"
    },
    downloadCv: {
        en: "Download CV",
        es: "Descargar CV"
    },
    aboutTitle: { 
        en: "About", 
        es: "Sobre Mí" 
    },
    meTitle: {
        en: "Me",
        es: "Yo"
    },
    meLine1: {
        en: "Computer Science student @ UNAM",
        es: "Estudiante de Ciencias de la Computación @ UNAM"
    },
    meLine2: {
        en: "In the industry, enthusiastic about Backend Architecture & ML",
        es: "En la industria, entusiasta de la Arquitectura Backend y el Machine Learning"
    },
    meLine3: {
        en: "In academia, interested about Automata Theory & Discrete Dynamical Systems",
        es: "En la academia, interesado por la Teoría de Autómatas y los Sistemas Dinámicos Discretos"
    },
    techJava: { en: "Java/Spring and Python for Backend", es: "Java/Spring y Python para Backend" },
    techPython: { en: "Python for experimental ML", es: "Python para ML experimental" },
    techScala: { en: "Scala for... why not?", es: "Scala por... ¿por qué no?" },
    resourcesTitle: { 
        en: "Resources I'm studying", 
        es: "Recursos que estoy estudiando" 
    },
    industryTitle: {
        en: "For Industry purposes",
        es: "Industria"
    },
    academiaTitle: {
        en: "For academic purposes (and hopefully for my thesis)",
        es: "Academia"
    },
    madeByMe: {
        en: "(made by me)",
        es: "(hecho por mí)"
    },
    tech: { 
        en: "Tech Stack", 
        es: "Stack Tecnológico" 
    }
};
---

<Layout title={`Luis Angel Moreno Delgado`}>
    <Header />
    
    <main class="min-h-screen px-4 sm:px-6 md:px-8 flex flex-col justify-center bg-white dark:bg-[#050505] transition-colors duration-500 selection:bg-[#e11d48]/20 selection:text-[#e11d48] dark:selection:text-white">
        
        <section class="max-w-5xl mx-auto w-full pt-32 sm:pt-48 pb-20 sm:pb-28 fade-in">
            <div class="flex flex-col lg:flex-row items-center lg:items-start gap-12 sm:gap-16 text-center lg:text-left">
                
                <div class="flex-shrink-0 relative group">
                    <div class="absolute -inset-2 border border-[#e11d48]/0 group-hover:border-[#e11d48]/50 transition-colors duration-700 ease-out z-0"></div>
                    
                    <div class="w-48 h-64 sm:w-64 sm:h-80 bg-zinc-100 dark:bg-zinc-900 border border-zinc-300 dark:border-white/10 p-2 flex items-center justify-center overflow-hidden transition-all duration-700 relative z-10 shadow-xl group-hover:shadow-[0_0_40px_rgba(225,29,72,0.15)]">
                        <img src={heroPhoto.src} alt="Luis Angel Moreno Delgado" class="w-full h-full object-cover grayscale contrast-125 transition-all duration-700 ease-out group-hover:scale-[1.02] group-hover:grayscale-0" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
                    </div>
                </div>
                
                <div class="flex flex-col items-center lg:items-start max-w-2xl mt-8 lg:mt-4">
                    
                    <h1 class="text-4xl sm:text-5xl md:text-7xl font-extrabold text-zinc-900 dark:text-white mb-8 tracking-tighter leading-[1.05]" data-en={translations.name.en} data-es={translations.name.es}>
                        {translations.name.es}
                    </h1>
                    
                    <p class="text-base sm:text-xl text-zinc-600 dark:text-zinc-400 mb-12 leading-relaxed font-light">
                        <span class="text-zinc-900 dark:text-zinc-200 font-medium" data-en={translations.heroDesc1.en} data-es={translations.heroDesc1.es}>{translations.heroDesc1.es}</span> 
                        <span class="italic text-[#e11d48] px-1 font-serif" data-en={translations.heroDesc2.en} data-es={translations.heroDesc2.es}>{translations.heroDesc2.es}</span> 
                        <span class="text-zinc-900 dark:text-zinc-200 font-medium" data-en={translations.heroDesc3.en} data-es={translations.heroDesc3.es}>{translations.heroDesc3.es}</span> 
                    </p>

                    <div class="flex flex-wrap gap-6 justify-center lg:justify-start w-full font-mono">
                        <a href="/projects" class="group relative px-8 py-3 text-xs tracking-[0.2em] uppercase text-white dark:text-black bg-zinc-900 dark:bg-white overflow-hidden transition-all duration-500" data-en={translations.viewProjects.en} data-es={translations.viewProjects.es}>
                            <span class="absolute inset-0 w-full h-full bg-[#e11d48] transform origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-500 ease-out"></span>
                            <span class="relative z-10 group-hover:text-white transition-colors duration-500">{translations.viewProjects.es}</span>
                        </a>
                        <a href="/contact" class="group relative px-8 py-3 text-xs tracking-[0.2em] uppercase text-zinc-900 dark:text-white hover:text-[#e11d48] dark:hover:text-[#e11d48] transition-colors duration-500" data-en={translations.getInTouch.en} data-es={translations.getInTouch.es}>
                            <span class="absolute inset-0 w-full h-full border border-zinc-300 dark:border-white/20 group-hover:border-[#e11d48] transition-colors duration-500"></span>
                            <span class="relative z-10">{translations.getInTouch.es}</span>
                        </a>
                    </div>
                    
                    <div class="mt-16 flex w-full justify-center lg:justify-start">
                        <a href={cvFile} download="CV_LuisAngelMorenoDelgado.pdf" class="group flex items-center gap-4 text-[10px] uppercase tracking-[0.3em] text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-all duration-500">
                            <span class="w-8 h-[1px] bg-zinc-300 dark:bg-zinc-700 group-hover:bg-[#e11d48] group-hover:w-12 transition-all duration-500 ease-out"></span>
                            <span data-en={translations.downloadCv.en} data-es={translations.downloadCv.es}>{translations.downloadCv.es}</span>
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <div class="w-full max-w-5xl mx-auto h-px bg-zinc-200 dark:bg-white/10 my-4 parallax-section"></div>

        <section class="max-w-5xl mx-auto py-24 fade-in w-full">
            <h2 class="text-xs font-mono uppercase tracking-[0.3em] text-zinc-400 dark:text-zinc-500 mb-16 text-center md:text-left" data-en={translations.aboutTitle.en} data-es={translations.aboutTitle.es}>{translations.aboutTitle.es}</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
                <div class="md:col-span-5 p-8 sm:p-10 bg-zinc-50 dark:bg-[#080808] border border-zinc-200 dark:border-white/5 hover:border-[#e11d48]/50 transition-colors duration-500 group">
                    <ul class="space-y-8 text-zinc-700 dark:text-zinc-400 text-sm sm:text-base font-light leading-relaxed">
                        <li class="flex items-start gap-5">
                            <span class="font-mono text-xs mt-1 text-[#e11d48]">01</span>
                            <span class="text-zinc-900 dark:text-zinc-300">
                                <span data-en={translations.meLine1.en} data-es={translations.meLine1.es}>{translations.meLine1.es}</span> 
                                (<a href="https://www.fciencias.unam.mx/" target="_blank" rel="noopener noreferrer" class="font-medium hover:text-[#e11d48] border-b border-transparent hover:border-[#e11d48] transition-all duration-300">FC UNAM</a>)
                            </span>
                        </li>
                        <li class="flex items-start gap-5">
                            <span class="font-mono text-xs mt-1 text-[#e11d48]">02</span>
                            <span class="text-zinc-900 dark:text-zinc-300" data-en={translations.meLine2.en} data-es={translations.meLine2.es}>{translations.meLine2.es}</span>
                        </li>
                        <li class="flex items-start gap-5">
                            <span class="font-mono text-xs mt-1 text-[#e11d48]">03</span>
                            <span class="text-zinc-900 dark:text-zinc-300" data-en={translations.meLine3.en} data-es={translations.meLine3.es}>{translations.meLine3.es}</span>
                        </li>
                    </ul>
                </div>

                <div class="md:col-span-7 p-8 sm:p-10 bg-zinc-50 dark:bg-[#080808] border border-zinc-200 dark:border-white/5 hover:border-[#e11d48]/50 transition-colors duration-500 group flex flex-col justify-center">
                    
                    <h3 class="text-lg font-bold text-zinc-900 dark:text-white mb-10 flex items-center gap-3">
                         <div class="w-1.5 h-1.5 bg-[#e11d48]"></div>
                         <span data-en={translations.resourcesTitle.en} data-es={translations.resourcesTitle.es}>{translations.resourcesTitle.es}</span>
                    </h3>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-12">
                        <div>
                            <h4 class="text-[10px] font-mono uppercase tracking-[0.2em] text-[#e11d48] mb-6" data-en={translations.industryTitle.en} data-es={translations.industryTitle.es}>{translations.industryTitle.es}</h4>
                            <ul class="space-y-6 text-sm text-zinc-600 dark:text-zinc-400 font-light">
                                <li class="group/item">
                                    <a href="https://www-oracle-com.translate.goog/technical-resources/articles/javase/bloch-effective-08-qa.html" target="_blank" rel="noopener noreferrer" class="flex flex-col gap-1">
                                        <span class="font-medium text-zinc-900 dark:text-zinc-200 group-hover/item:text-[#e11d48] transition-colors duration-300">Effective Java</span>
                                        <span class="text-[10px] font-mono tracking-widest uppercase opacity-70">Joshua Bloch</span>
                                    </a>
                                </li>
                                <li class="group/item flex flex-col gap-1">
                                    <span class="font-medium text-zinc-900 dark:text-zinc-200">Spring</span>
                                    <span class="text-[10px] font-mono tracking-widest uppercase opacity-70">Doc & Community</span>
                                </li>
                                <li class="group/item">
                                    <a href="https://github.com/c4mdax/Machine_Learning/blob/main/Roadmap/ROADMAP.md" target="_blank" rel="noopener noreferrer" class="flex flex-col gap-1">
                                        <span class="font-medium text-zinc-900 dark:text-zinc-200 group-hover/item:text-[#e11d48] transition-colors duration-300">ML Roadmap</span>
                                        <span class="text-[10px] font-mono tracking-widest uppercase opacity-70 text-[#e11d48]" data-en={translations.madeByMe.en} data-es={translations.madeByMe.es}>{translations.madeByMe.es}</span>
                                    </a>
                                </li>
                            </ul>
                        </div>

                        <div>
                            <h4 class="text-[10px] font-mono uppercase tracking-[0.2em] text-[#e11d48] mb-6" data-en={translations.academiaTitle.en} data-es={translations.academiaTitle.es}>{translations.academiaTitle.es}</h4>
                            <ul class="space-y-6 text-sm text-zinc-600 dark:text-zinc-400 font-light">
                                <li class="group/item">
                                    <a href="https://wolframscience.com/" target="_blank" rel="noopener noreferrer" class="flex flex-col gap-1">
                                        <span class="font-medium text-zinc-900 dark:text-zinc-200 group-hover/item:text-[#e11d48] transition-colors duration-300">A New Kind of Science</span>
                                        <span class="text-[10px] font-mono tracking-widest uppercase opacity-70">Stephen Wolfram</span>
                                    </a>
                                </li>
                                <li class="group/item">
                                    <a href="https://www.semanticscholar.org/paper/Collision-Based-Computing-Adamatzky-Durand-Lose/e0d199d9ae0ebfdf18f589dee027f26e05c44ec5" target="_blank" rel="noopener noreferrer" class="flex flex-col gap-1">
                                        <span class="font-medium text-zinc-900 dark:text-zinc-200 group-hover/item:text-[#e11d48] transition-colors duration-300">Collision-based Computing</span>
                                        <span class="text-[10px] font-mono tracking-widest uppercase opacity-70">A. Adamatzky</span>
                                    </a>
                                </li>
                                <li class="group/item">
                                    <a href="https://www.taylorfrancis.com/books/mono/10.1201/9780429280801/introduction-chaotic-dynamical-systems-robert-devaney" target="_blank" rel="noopener noreferrer" class="flex flex-col gap-1">
                                        <span class="font-medium text-zinc-900 dark:text-zinc-200 group-hover/item:text-[#e11d48] transition-colors duration-300">Chaotic Dynamical Systems</span>
                                        <span class="text-[10px] font-mono tracking-widest uppercase opacity-70">R. Devaney</span>
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="max-w-5xl mx-auto pt-12 pb-32 fade-in w-full overflow-hidden">
            <h2 class="text-[10px] font-mono uppercase tracking-[0.4em] text-zinc-400 dark:text-zinc-600 mb-12 text-center" data-en={translations.tech.en} data-es={translations.tech.es}>{translations.tech.es}</h2>
            
            <div class="carousel-container font-mono opacity-80 hover:opacity-100 transition-opacity duration-700">
                <div class="carousel-track">
                    {[1, 2].map(() => (
                        <>
                            <div class="px-10 py-4 text-xs sm:text-sm font-bold uppercase tracking-[0.2em] text-zinc-900 dark:text-zinc-200 border border-zinc-200 dark:border-white/5 hover:border-[#e11d48] hover:text-[#e11d48] dark:hover:text-[#e11d48] transition-colors cursor-default bg-zinc-50 dark:bg-transparent shadow-sm">JAVA</div>
                            <div class="px-10 py-4 text-xs sm:text-sm font-bold uppercase tracking-[0.2em] text-zinc-900 dark:text-zinc-200 border border-zinc-200 dark:border-white/5 hover:border-[#e11d48] hover:text-[#e11d48] dark:hover:text-[#e11d48] transition-colors cursor-default bg-zinc-50 dark:bg-transparent shadow-sm">SPRING</div>
                            <div class="px-10 py-4 text-xs sm:text-sm font-bold uppercase tracking-[0.2em] text-zinc-900 dark:text-zinc-200 border border-zinc-200 dark:border-white/5 hover:border-[#e11d48] hover:text-[#e11d48] dark:hover:text-[#e11d48] transition-colors cursor-default bg-zinc-50 dark:bg-transparent shadow-sm">SCALA</div>
                            <div class="px-10 py-4 text-xs sm:text-sm font-bold uppercase tracking-[0.2em] text-zinc-900 dark:text-zinc-200 border border-zinc-200 dark:border-white/5 hover:border-[#e11d48] hover:text-[#e11d48] dark:hover:text-[#e11d48] transition-colors cursor-default bg-zinc-50 dark:bg-transparent shadow-sm">PYTHON</div>
                            <div class="px-10 py-4 text-xs sm:text-sm font-bold uppercase tracking-[0.2em] text-zinc-900 dark:text-zinc-200 border border-zinc-200 dark:border-white/5 hover:border-[#e11d48] hover:text-[#e11d48] dark:hover:text-[#e11d48] transition-colors cursor-default bg-zinc-50 dark:bg-transparent shadow-sm">SQL</div>
                            <div class="px-10 py-4 text-xs sm:text-sm font-bold uppercase tracking-[0.2em] text-zinc-900 dark:text-zinc-200 border border-zinc-200 dark:border-white/5 hover:border-[#e11d48] hover:text-[#e11d48] dark:hover:text-[#e11d48] transition-colors cursor-default bg-zinc-50 dark:bg-transparent shadow-sm">ML / AI</div>
                            <div class="px-10 py-4 text-xs sm:text-sm font-bold uppercase tracking-[0.2em] text-zinc-900 dark:text-zinc-200 border border-zinc-200 dark:border-white/5 hover:border-[#e11d48] hover:text-[#e11d48] dark:hover:text-[#e11d48] transition-colors cursor-default bg-zinc-50 dark:bg-transparent shadow-sm">LLMS</div>
                            <div class="px-10 py-4 text-xs sm:text-sm font-bold uppercase tracking-[0.2em] text-zinc-900 dark:text-zinc-200 border border-zinc-200 dark:border-white/5 hover:border-[#e11d48] hover:text-[#e11d48] dark:hover:text-[#e11d48] transition-colors cursor-default bg-zinc-50 dark:bg-transparent shadow-sm">DATA ENG</div>
                            <div class="px-10 py-4 text-xs sm:text-sm font-bold uppercase tracking-[0.2em] text-zinc-900 dark:text-zinc-200 border border-zinc-200 dark:border-white/5 hover:border-[#e11d48] hover:text-[#e11d48] dark:hover:text-[#e11d48] transition-colors cursor-default bg-zinc-50 dark:bg-transparent shadow-sm">DOCKER</div>
                        </>
                    ))}
                </div>
            </div>
        </section>
    </main>

    <Footer />

    <style>
        .carousel-container {
            width: 100%;
            overflow: hidden;
            position: relative;
            mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
            -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
        }

        .carousel-track {
            display: flex;
            gap: 1.5rem;
            width: max-content;
            animation: scroll 35s linear infinite;
        }

        .carousel-track:hover {
            animation-play-state: paused;
        }

        @keyframes scroll {
            0% { transform: translateX(0); }
            100% { transform: translateX(calc(-50% - 0.75rem)); } 
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const observerOptions = {
                root: null,
                rootMargin: '0px',
                threshold: 0.1
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('.fade-in').forEach(el => {
                observer.observe(el);
            });

            window.addEventListener('scroll', () => {
                const scrolled = window.pageYOffset;
                document.querySelectorAll('.parallax-section').forEach(section => {
                    const speed = 0.08;
                    (section as HTMLElement).style.transform = `translateY(${scrolled * speed}px)`;
                });
            });
        });
    </script>
</Layout>