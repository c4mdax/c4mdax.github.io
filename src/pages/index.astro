---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import myPhoto from '../assets/photo.jpeg';

const translations = {
    subtitle: { en: "Computer Science Student", es: "Estudiante de Ciencias de la Computación" },
    description: {
        en: "I work at the intersection of theory and engineering, building reliable systems grounded in formal foundations and solid architecture.",
        es: "Trabajo en la intersección entre teoría e ingeniería, construyendo sistemas confiables basados en fundamentos formales y arquitectura sólida."
    },
    viewResearch: { en: "View Research", es: "View Research" },
    selectedWork: { en: "Selected Work", es: "Selected Work" }
} as const;
---

<Layout title="Luis Angel Moreno Delgado">

    <main class="min-h-screen bg-[#020202] text-zinc-300 overflow-x-hidden relative flex flex-col justify-between antialiased">

        <div class="absolute inset-0 opacity-[0.035] noise-bg pointer-events-none"></div>
        <div class="absolute inset-0 grid-overlay pointer-events-none"></div>

        <header class="relative z-20 border-b border-white/[0.05] shrink-0">
            <div class="max-w-[1400px] mx-auto px-10 py-4 flex items-center justify-between">
                <div class="font-serif text-[20px] tracking-wide text-white font-light">
                    C4MDAX
                </div>
                <div class="hidden md:flex items-center gap-10">
                    <nav class="flex items-center gap-10 font-mono">
                        <a href="#" class="text-[13px] uppercase tracking-[0.2em] text-zinc-400 hover:text-white transition-colors duration-300">Research</a>
                        <a href="#" class="text-[13px] uppercase tracking-[0.2em] text-zinc-400 hover:text-white transition-colors duration-300">Projects</a>
                        <a href="#" class="text-[13px] uppercase tracking-[0.2em] text-zinc-400 hover:text-white transition-colors duration-300">Publications</a>
                        <a href="#" class="text-[13px] uppercase tracking-[0.2em] text-zinc-400 hover:text-white transition-colors duration-300">About</a>
                    </nav>
                    <div class="border-l border-white/[0.08] pl-8 text-zinc-400">
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                            <rect x="9.5" y="1" width="5.5" height="5.5" fill="currentColor" opacity="0.8"/>
                            <rect x="1" y="9.5" width="5.5" height="5.5" fill="currentColor" opacity="0.8"/>
                            <rect x="9.5" y="9.5" width="5.5" height="5.5" fill="currentColor" opacity="0.8"/>
                        </svg>
                    </div>
                </div>
            </div>
        </header>

        <section class="relative z-10 max-w-[1400px] w-full mx-auto px-10 pt-8 pb-4 shrink-0">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
                <div class="max-w-[540px]">
                    <h1 class="font-serif leading-none tracking-tight text-white font-light mb-5" style="font-size: clamp(40px, 6.5vw, 56px);">
                        Luis Angel Moreno Delgado
                    </h1>
                    <div class="flex items-center gap-4 mb-4">
                        <Image 
                            src={myPhoto} 
                            alt="Portrait of Angel" 
                            class="w-12 h-12 rounded-full border border-white/[0.1] object-cover flex-shrink-0"
                            widths={[96]}
                            aspectRatio={1/1}
                        />
                        <p class="font-mono text-[14px] uppercase tracking-[0.2em] text-zinc-400 flex-1">
                            {translations.subtitle.en}
                        </p>
                    </div>
                    <p class="font-mono text-[15px] leading-normal text-zinc-300 font-light max-w-[480px]">
                        {translations.description.en}
                    </p>
                    <div class="mt-6">
                        <a href="#" class="font-mono group inline-flex items-center gap-3 text-[13px] uppercase tracking-[0.2em] text-zinc-400 hover:text-white transition-colors duration-500">
                            <span class="text-zinc-400 group-hover:translate-x-1 transition-transform duration-300">›</span>
                            <span class="border-b border-dashed border-zinc-600 pb-0.5">{translations.viewResearch.en}</span>
                        </a>
                    </div>
                </div>
                <div class="relative hidden lg:flex items-center justify-center" style="height: clamp(160px, 20vh, 260px);">
                    <canvas id="triangleCanvas" class="w-full h-full opacity-[0.25]"></canvas>
                    <div class="font-mono absolute bottom-0 right-0 text-zinc-500 text-[11px] tracking-wider">
                        Rule 110
                    </div>
                </div>
            </div>
        </section>

        <div class="max-w-[1400px] w-full mx-auto px-10 shrink-0">
            <div class="h-px bg-white/[0.05]"></div>
        </div>

        <section class="relative z-10 max-w-[1400px] w-full mx-auto px-10 py-5 shrink-0">
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-y-6">
                <div class="pr-6 xl:border-r border-white/[0.05]">
                    <div class="text-zinc-300 mb-3">
                        <svg width="24" height="24" viewBox="0 0 32 32" fill="none">
                            <path d="M24 6H10L18 16L10 26H24" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"/>
                        </svg>
                    </div>
                    <h3 class="font-mono text-[13px] tracking-[0.2em] text-white mb-2 font-normal">THEORY</h3>
                    <p class="font-mono text-zinc-400 leading-snug text-[14px] font-light pr-4">
                        Automata theory, formal languages, computability, and complexity.
                    </p>
                </div>
                <div class="xl:px-6 xl:border-r border-white/[0.05]">
                    <div class="text-zinc-300 mb-3">
                        <svg width="24" height="24" viewBox="0 0 32 32" fill="none">
                            <path d="M16 4L28 10.5V21.5L16 28L4 21.5V10.5L16 4Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                            <path d="M4 10.5L16 17M28 10.5L16 17M16 17V28" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <h3 class="font-mono text-[13px] tracking-[0.2em] text-white mb-2 font-normal">ARCHITECTURE</h3>
                    <p class="font-mono text-zinc-400 leading-snug text-[14px] font-light pr-4">
                        Designing modular, scalable and maintainable software systems.
                    </p>
                </div>
                <div class="xl:px-6 xl:border-r border-white/[0.05]">
                    <div class="text-zinc-300 mb-3">
                        <svg width="24" height="24" viewBox="0 0 32 32" fill="none">
                            <path d="M11 10L4 16L11 22M21 10L28 16L21 22" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M18 5L14 27" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                    </div>
                    <h3 class="font-mono text-[13px] tracking-[0.2em] text-white mb-2 font-normal">ENGINEERING</h3>
                    <p class="font-mono text-zinc-400 leading-snug text-[14px] font-light pr-4">
                        Backend systems, compilers, tooling and developer infrastructure.
                    </p>
                </div>
                <div class="xl:pl-6">
                    <div class="text-zinc-300 mb-3">
                        <svg width="24" height="24" viewBox="0 0 32 32" fill="none">
                            <ellipse cx="16" cy="8" rx="10" ry="4" stroke="currentColor" stroke-width="2"/>
                            <path d="M6 8V24C6 26.2 10.5 28 16 28C21.5 28 26 26.2 26 24V8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                            <path d="M6 16C6 18.2 10.5 20 16 20C21.5 20 26 18.2 26 16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                    </div>
                    <h3 class="font-mono text-[13px] tracking-[0.2em] text-white mb-2 font-normal">SYSTEMS</h3>
                    <p class="font-mono text-zinc-400 leading-snug text-[14px] font-light pr-4">
                        Building performant and reliable systems that solve real problems.
                    </p>
                </div>
            </div>
        </section>

        <div class="max-w-[1400px] w-full mx-auto px-10 shrink-0">
            <div class="h-px bg-white/[0.05]"></div>
        </div>

        <section class="relative z-10 max-w-[1400px] w-full mx-auto px-10 py-5 shrink-0 flex-1 flex flex-col justify-center">
            <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-4 font-mono gap-4">
                <h2 class="text-[13px] uppercase tracking-[0.2em] text-zinc-400 font-normal">
                    {translations.selectedWork.en}
                </h2>
                <a href="#" class="text-[12px] uppercase tracking-[0.2em] text-zinc-400 hover:text-white transition-colors duration-500">
                    VIEW ALL PROJECTS →
                </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 font-mono">
                
                <article class="border border-white/[0.05] p-5 hover:border-white/[0.15] transition-colors duration-500 bg-[#030303] relative overflow-hidden flex flex-col justify-between" style="min-height: 160px;">
                    <div>
                        <h3 class="text-white text-[14px] tracking-wide font-normal mb-2">
                            COMPILERS &amp; IRs
                        </h3>
                        <p class="text-zinc-400 leading-snug text-[14px] max-w-[240px] font-light">
                            Exploring intermediate representations, optimizations and program analysis.
                        </p>
                    </div>
                    <div class="mt-3 text-zinc-500 text-sm">→</div>
                    <div class="absolute bottom-4 right-4 opacity-[0.25] pointer-events-none scale-90 origin-bottom-right">
                        <svg width="90" height="80" viewBox="0 0 90 80" fill="none">
                            <rect x="36" y="10" width="18" height="12" rx="2" stroke="white" stroke-width="1.5"/>
                            <rect x="16" y="35" width="18" height="12" rx="2" stroke="white" stroke-width="1.5"/>
                            <rect x="56" y="35" width="18" height="12" rx="2" stroke="white" stroke-width="1.5"/>
                            <rect x="6" y="60" width="16" height="10" rx="2" stroke="white" stroke-width="1.5"/>
                            <rect x="28" y="60" width="16" height="10" rx="2" stroke="white" stroke-width="1.5"/>
                            <path d="M45 22 L25 35 M45 22 L65 35" stroke="white" stroke-width="1.5"/>
                            <path d="M25 47 L14 60 M25 47 L36 60" stroke="white" stroke-width="1.5"/>
                            <path d="M74 41 h8 v15 h-20 v-9" stroke="white" stroke-width="1" stroke-dasharray="2 2" fill="none"/>
                            <polygon points="62,47 60,50 64,50" fill="white" />
                        </svg>
                    </div>
                </article>

                <article class="border border-white/[0.05] p-5 hover:border-white/[0.15] transition-colors duration-500 bg-[#030303] relative overflow-hidden flex flex-col justify-between" style="min-height: 160px;">
                    <div>
                        <h3 class="text-white text-[14px] tracking-wide font-normal mb-2">
                            AUTOMATA &amp; LANGUAGES
                        </h3>
                        <p class="text-zinc-400 leading-snug text-[14px] max-w-[240px] font-light">
                            Research and implementations in automata theory and formal language processing.
                        </p>
                    </div>
                    <div class="mt-3 text-zinc-500 text-sm">→</div>
                    <div class="absolute bottom-4 right-4 opacity-[0.25] pointer-events-none scale-90 origin-bottom-right">
                        <svg width="90" height="80" viewBox="0 0 90 80" fill="none">
                            <defs>
                                <marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                                    <path d="M 0 1 L 10 5 L 0 9 z" fill="white"/>
                                </marker>
                            </defs>
                            <circle cx="25" cy="40" r="12" stroke="white" stroke-width="1.5"/>
                            <circle cx="65" cy="40" r="12" stroke="white" stroke-width="1.5"/>
                            <circle cx="65" cy="40" r="9" stroke="white" stroke-width="1"/>
                            <line x1="2" y1="40" x2="13" y2="40" stroke="white" stroke-width="1.5" marker-end="url(#arrow)"/>
                            <path d="M 33 31 Q 45 15 57 31" stroke="white" stroke-width="1.5" fill="none" marker-end="url(#arrow)"/>
                            <path d="M 57 49 Q 45 65 33 49" stroke="white" stroke-width="1.5" fill="none" marker-end="url(#arrow)"/>
                            <path d="M 72 30 C 90 10, 90 40, 76 38" stroke="white" stroke-width="1.5" fill="none" marker-end="url(#arrow)"/>
                        </svg>
                    </div>
                </article>

                <article class="border border-white/[0.05] p-5 hover:border-white/[0.15] transition-colors duration-500 bg-[#030303] relative overflow-hidden flex flex-col justify-between" style="min-height: 160px;">
                    <div>
                        <h3 class="text-white text-[14px] tracking-wide font-normal mb-2">
                            SYSTEMS &amp; INFRASTRUCTURE
                        </h3>
                        <p class="text-zinc-400 leading-snug text-[14px] max-w-[240px] font-light">
                            Backend services, APIs and developer tools focused on reliability and scale.
                        </p>
                    </div>
                    <div class="mt-3 text-zinc-500 text-sm">→</div>
                    <div class="absolute bottom-4 right-4 opacity-[0.25] pointer-events-none scale-90 origin-bottom-right">
                        <svg width="90" height="80" viewBox="0 0 90 80" fill="none">
                            <ellipse cx="25" cy="45" rx="12" ry="4" stroke="white" stroke-width="1.5"/>
                            <path d="M13 45 V55 C13 57.2 18.4 59 25 59 C31.6 59 37 57.2 37 55 V45" stroke="white" stroke-width="1.5" fill="none"/>
                            <path d="M13 55 V65 C13 67.2 18.4 69 25 69 C31.6 69 37 67.2 37 65 V55" stroke="white" stroke-width="1.5" fill="none"/>
                            <ellipse cx="65" cy="45" rx="12" ry="4" stroke="white" stroke-width="1.5"/>
                            <path d="M53 45 V55 C53 57.2 58.4 59 65 59 C71.6 59 77 57.2 77 55 V45" stroke="white" stroke-width="1.5" fill="none"/>
                            <path d="M53 55 V65 C53 67.2 58.4 69 65 69 C71.6 69 77 67.2 77 65 V55" stroke="white" stroke-width="1.5" fill="none"/>
                            <rect x="35" y="10" width="20" height="12" rx="2" stroke="white" stroke-width="1.5"/>
                            <circle cx="45" cy="16" r="2" fill="white"/>
                            <path d="M40 22 L25 41" stroke="white" stroke-width="1.5" stroke-dasharray="2 2"/>
                            <path d="M50 22 L65 41" stroke="white" stroke-width="1.5" stroke-dasharray="2 2"/>
                            <path d="M25 41 L23 37 M25 41 L28 37" stroke="white" stroke-width="1.5" fill="none"/>
                            <path d="M65 41 L62 37 M65 41 L67 37" stroke="white" stroke-width="1.5" fill="none"/>
                        </svg>
                    </div>
                </article>

            </div>
        </section>

        <footer class="relative z-10 max-w-[1400px] w-full mx-auto px-10 shrink-0 font-mono py-4">
            <div class="h-px bg-white/[0.05] mb-4"></div>
            <div class="flex flex-col md:flex-row gap-4 items-center justify-between">
                <div class="text-zinc-500 text-[12px] tracking-wider">
                    $ whoami &nbsp; c4mdax@researcher:~-
                </div>
                <div class="flex items-center gap-6 text-zinc-500">
                    <a href="#" class="hover:text-white transition-colors duration-500">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z"/>
                        </svg>
                    </a>
                    <span class="text-zinc-700 text-[11px]">|</span>
                    <a href="#" class="hover:text-white transition-colors duration-500">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="2" y="4" width="20" height="16" rx="2"/>
                            <path d="M2 7l10 7 10-7"/>
                        </svg>
                    </a>
                    <span class="text-zinc-700 text-[11px]">|</span>
                    <a href="#" class="hover:text-white transition-colors duration-500">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                        </svg>
                    </a>
                </div>
            </div>
        </footer>

    </main>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@300;400;500&display=swap');

        .font-serif { font-family: 'Crimson Text', serif; }
        .font-mono { font-family: 'JetBrains Mono', monospace; }

        .noise-bg {
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        }
        .grid-overlay {
            background-image:
                linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
            background-size: 80px 80px;
        }
    </style>

    <script>
        function initTriangleAutomata() {
            const canvas = document.getElementById('triangleCanvas') as HTMLCanvasElement | null;
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            if (!ctx) return;
            const width = canvas.clientWidth;
            const height = canvas.clientHeight;
            canvas.width = width;
            canvas.height = height;
            ctx.clearRect(0, 0, width, height);

            const cell = 4;
            const rows = Math.floor(height / cell);
            let current = new Array(Math.floor(width / cell)).fill(0);
            current[Math.floor(current.length / 2)] = 1;
            
            function rule110(l: number, c: number, r: number): number {
                const p = (l << 2) | (c << 1) | r;
                return [0,1,1,1,0,1,1,0][p] ?? 0;
            }
            
            for (let y = 0; y < rows; y++) {
                for (let x = 0; x < current.length; x++) {
                    if (current[x]) {
                        ctx.fillStyle = 'rgba(150,150,150,0.15)';
                        ctx.fillRect(x * cell, y * cell, cell - 1, cell - 1);
                    }
                }
                const next = new Array(current.length).fill(0);
                for (let i = 1; i < current.length - 1; i++) {
                    next[i] = rule110(current[i-1], current[i], current[i+1]);
                }
                current = next;
            }
        }
        document.addEventListener('DOMContentLoaded', initTriangleAutomata);
    </script>

</Layout>w