---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import myPhoto from '../assets/photo.jpeg';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const posts = ['backend-roadmap', 'collision-based-computing', 'cellular-automata']
  .map(slug => allPosts.find(p => p.slug === slug))
  .filter(Boolean);

const allProjects = await getCollection('projects');
const projects = ['atomicpulse', 'dragan-rag']
  .map(slug => allProjects.find(p => p.slug === slug))
  .filter(Boolean);

const t = {
  desc: { en: "3rd year Computer Science student, focused on pragmatic engineering with solid theoretical foundations. In the industry, I have an interest and focus on Backend+Distributed Systems and AI. In academia, I am interested in Automata Theory (Cellular Automata) and Formal Methods, this last result of my experience as a QA engineer and my interest in correctness and formalization of software.", es: "Estudiante de último año en Ciencias de la Computación, entusiasta de lo pragmático cuando emerge de teoría sólida y consistente. En la industria tengo interés y enfoque en Backend+Cómputo Distribuido e IA. En lo académico, estoy muy interesado en Teoría de Autómatas (énfasis en Autómatas Celulares) y Métodos Formales, éste último producto de mi experiencia como QA y mi interés por la correctitud y formalización en la construcción del software." },
  currentlyTitle: { en: "Currently", es: "Actualmente" },
  workTitle: { en: "Featured Public Study", es: "Escritos y Estudio Público Destacado" },
  workBtn: { en: "VIEW ALL →", es: "VER TODO →" },
  workDisclaimer: { en: "None of the posts presented here were written with AI.", es: "Ninguno de los escritos presentados aquí han sido escritos con IA." },
  projTitle: { en: "Featured Projects", es: "Proyectos Destacados" },
  projBtn: { en: "VIEW ALL →", es: "VER TODO →" },
  profileTitle: { en: "Profile", es: "Perfil" },
  readLabel: { en: "Read →", es: "Leer →" },
  viewProjectLabel: { en: "View project →", es: "Ver proyecto →" }
};

const skills = [
  { 
    en: "THEORY", es: "TEORÍA", 
    descEn: "Formal Methods, Cellular Automata.", 
    descEs: "Métodos Formales, Autómatas Celulares.",
    icon: '<path d="M24 6H10L18 16L10 26H24" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>' 
  },
  { 
    en: "ENGINEERING", es: "INGENIERÍA", 
    descEn: "Backend+Distributed Systems, AI", 
    descEs: "Backend+Sistemas Distribuidos, IA",
    icon: '<path d="M11 10L4 16L11 22M21 10L28 16L21 22" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M18 5L14 27" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>' 
  },
  { 
    en: "STACK", es: "STACK", 
    descEn: "JVM (Java/Scala), Python, SQL/NoSQL, Docker, Linux systems.", 
    descEs: "JVM (Java/Scala), Python, SQL/NoSQL, Docker, Linux (Arch).",
    icon: '<path d="M16 4L28 10.5V21.5L16 28L4 21.5V10.5L16 4Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M4 10.5L16 17M28 10.5L16 17M16 17V28" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>' 
  }
];

const sWrap = "relative z-10 max-w-[1100px] w-full mx-auto px-6 md:px-10 shrink-0";

const T = {
  heading: "font-light tracking-tight text-white",
  subheading: "font-mono uppercase tracking-[0.2em] text-zinc-500",
  body: "text-zinc-400 leading-relaxed",
  meta: "text-zinc-600 italic",
  keywords: "font-mono text-zinc-600"
};
---

<Layout title="Luis Angel Moreno Delgado">
  <main class="font-serif min-h-screen bg-[#121212] text-zinc-300 overflow-x-hidden relative flex flex-col justify-between antialiased selection:bg-blue-500/30 selection:text-white">
    <Header />

    <section class={`${sWrap} pt-12 md:pt-20 pb-8 md:pb-10`}>
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-8 md:gap-12 items-start">
        <div>
          <h1 class="leading-[0.95] tracking-[-0.02em] text-white font-light mb-8" style="font-size: clamp(48px, 8vw, 80px);">
            Luis Angel<br/> Moreno Delgado
          </h1>

          <div class="lg:hidden mb-5">
            <Image src={myPhoto} alt="Portrait" class="w-28 h-28 object-cover" widths={[192, 384]} sizes="(max-width: 768px) 192px, 384px" quality={84} />
          </div>

          <p class={`${T.body} text-[17px] md:text-[19px] max-w-[640px]`} data-en={t.desc.en} data-es={t.desc.es}>{t.desc.en}</p>
        </div>

        <div class="hidden lg:flex justify-end pt-2">
          <Image src={myPhoto} alt="Portrait" class="w-50 h-50 object-cover" widths={[192, 384]} sizes="(max-width: 768px) 192px, 384px" quality={85} />
        </div>
      </div>
    </section>

    <div class={sWrap}><div class="h-px bg-white/[0.06]"></div></div>

    <section class={`${sWrap} py-6 md:py-8`}>
      <h2 class={`${T.heading} mb-4`} style="font-size: clamp(24px, 4vw, 32px);" data-en={t.currentlyTitle.en} data-es={t.currentlyTitle.es}>
        <span class="block w-8 h-px bg-zinc-600 mb-3"></span>
        {t.currentlyTitle.en}
      </h2>
      
      <ul class={`${T.body} text-[17px] md:text-[19px] space-y-1.5 list-disc list-inside marker:text-zinc-600`}>
        <li>
          <span data-en="Studying my roadmap of robust " data-es="Estudiando mi roadmap de ">Studying robust </span>
          <a href="/posts/backend-roadmap/" class="text-blue-300 hover:text-blue-200 underline decoration-white/20 hover:decoration-blue-300/50 underline-offset-4 transition-all duration-300" data-en="backend development" data-es="desarrollo backend robusto">backend development</a><span data-en="." data-es=".">.</span>
        </li>
        <li data-en="Delving deeper into the JVM ecosystem (Java/Scala)." data-es="Profundizando en el ecosistema JVM (Java/Scala).">Delving deeper into the JVM ecosystem (Java/Scala).</li>
        <li data-en="Introduction to formal methods with TLA+." data-es="Introduciéndome a Métodos Formales con TLA+.">Introduction to formal methods with TLA+.</li>
      </ul>
    </section>

    <div class={sWrap}><div class="h-px bg-white/[0.06]"></div></div>

    <section class={`${sWrap} py-6 md:py-8`}>
      <h2 class={`${T.heading} mb-5`} style="font-size: clamp(24px, 4vw, 32px);" data-en={t.profileTitle.en} data-es={t.profileTitle.es}>
        <span class="block w-8 h-px bg-zinc-600 mb-3"></span>
        {t.profileTitle.en}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        {skills.map(s => (
          <div class="group border-l border-white/[0.06] pl-5 md:pl-6 transition-colors duration-500 hover:border-white/15">
            <div class="text-zinc-500 mb-3 group-hover:text-zinc-400 transition-colors duration-500">
              <svg width="20" height="20" viewBox="0 0 32 32" fill="none" set:html={s.icon} />
            </div>
            <h3 class={`${T.subheading} text-[13px] md:text-[16px] mb-3`} data-en={s.en} data-es={s.es}>{s.en}</h3>
            <p class={`${T.body} text-[17px] md:text-[19px] mb-3`} data-en={s.descEn} data-es={s.descEs}>{s.descEn}</p>
            <p class={`${T.keywords} text-[11px] md:text-[12px] leading-relaxed`} data-en={s.keywordsEn} data-es={s.keywordsEs}>
              {s.keywordsEn}
            </p>
          </div>
        ))}
      </div>
    </section>

    <div class={sWrap}><div class="h-px bg-white/[0.06]"></div></div>

    <section class={`${sWrap} py-6 md:py-8`}>
      <div class="flex flex-col sm:flex-row sm:items-baseline justify-between mb-2 gap-3">
        <h2 class={`${T.heading}`} style="font-size: clamp(24px, 4vw, 32px);" data-en={t.workTitle.en} data-es={t.workTitle.es}>
          <span class="block w-8 h-px bg-zinc-600 mb-3"></span>
          {t.workTitle.en}
        </h2>
        <a href="/posts/" class={`${T.subheading} text-[12px] md:text-[13px] hover:text-white transition-colors duration-500`} data-en={t.workBtn.en} data-es={t.workBtn.es}>{t.workBtn.en}</a>
      </div>

      <p class={`${T.meta} text-[14px] md:text-[15px] mb-4`} data-en={t.workDisclaimer.en} data-es={t.workDisclaimer.es}>
        {t.workDisclaimer.en}
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-white/[0.06]">
        {posts.map(p => (
          <a href={`/posts/${p.slug}`} class="group p-5 md:p-6 hover:bg-white/[0.02] transition-all duration-500 bg-[#121212] block relative flex flex-col justify-between min-h-[160px]">
            <div>
              <h3 class="font-mono text-[13px] md:text-[16px] tracking-[0.15em] text-zinc-400 mb-4 group-hover:text-white transition-colors duration-300">{p.data.title}</h3>
              <p class={`${T.body} text-[17px] md:text-[19px]`}>{p.data.description}</p>
            </div>
            <span class={`${T.meta} text-[18px] mt-3 group-hover:text-zinc-400 transition-colors duration-300`} data-en={t.readLabel.en} data-es={t.readLabel.es}>{t.readLabel.en}</span>
          </a>
        ))}
      </div>
    </section>

    <div class={sWrap}><div class="h-px bg-white/[0.06]"></div></div>

    <section class={`${sWrap} py-6 md:py-8`}>
      <div class="flex flex-col sm:flex-row sm:items-baseline justify-between mb-4 gap-3">
        <h2 class={`${T.heading}`} style="font-size: clamp(24px, 4vw, 32px);" data-en={t.projTitle.en} data-es={t.projTitle.es}>
          <span class="block w-8 h-px bg-zinc-600 mb-3"></span>
          {t.projTitle.en}
        </h2>
        <a href="/projects/" class={`${T.subheading} text-[12px] md:text-[13px] hover:text-white transition-colors duration-500`} data-en={t.projBtn.en} data-es={t.projBtn.es}>{t.projBtn.en}</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-white/[0.06]">
        {projects.map(p => (
          <a href={`/projects/${p.slug}`} class="group p-5 md:p-6 hover:bg-white/[0.02] transition-all duration-500 bg-[#121212] block relative flex flex-col justify-between min-h-[160px]">
            <div>
              <h3 class="font-mono text-[13px] md:text-[16px] tracking-[0.15em] text-zinc-400 mb-2 group-hover:text-white transition-colors duration-300">{p.data.title}</h3>
              <p class={`${T.body} text-[16px] md:text-[17px]`}>{p.data.description}</p>
            </div>
            <span class={`${T.meta} text-[18px] mt-3 group-hover:text-zinc-400 transition-colors duration-300`} data-en={t.viewProjectLabel.en} data-es={t.viewProjectLabel.es}>{t.viewProjectLabel.en}</span>
          </a>
        ))}
      </div>
    </section>

    <Footer />
  </main>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap');
    
    .font-serif { 
      font-family: 'Crimson Text', Georgia, 'Times New Roman', serif; 
    }
    
    .font-mono {
      font-family: 'JetBrains Mono', 'Courier New', monospace;
    }
  </style>
</Layout>