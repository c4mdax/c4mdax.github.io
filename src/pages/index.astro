---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import heroPhoto from '../assets/photo.jpeg';
import cvFile from '../assets/CV_2026_LuisAngelMorenoDelgado.pdf';

const translations = {
    greeting: { 
        en: "", 
        es: "" 
    },
    name: { 
        en: "Luis Angel Moreno Delgado", 
        es: "Luis Angel Moreno Delgado" 
    },
    heroDesc1: {
        en: "Computer Science Student",
        es: "Estudiante de Ciencias de la Computación"
    },
    heroDesc2: {
        en: "&",
        es: "y"
    },
    heroDesc3: {
        en: "Backend - ML enthusiast",
        es: "Entusiasta de la Arquitectura Backend y del Aprendizaje Automático"
    },
    heroDesc4: {
        en: "",
        es: ""
    },
    viewProjects: { 
        en: "Projects", 
        es: "Proyectos" 
    },
    getInTouch: { 
        en: "Contact", 
        es: "Contacto" 
    },
    roleTitle: {
        en: "Software Developer",
        es: "Desarrollador de Software"
    },
    downloadCv: {
        en: "Download CV",
        es: "Descargar CV"
    },
    aboutTitle: { 
        en: "About", 
        es: "Sobre" 
    },
    meTitle: {
        en: "Me",
        es: "Yo"
    },
    meLine1: {
        en: "Computer Science student @ UNAM",
        es: "Estudiante de Ciencias de la Computación @ UNAM"
    },
    meLine2: {
        en: "In the industry, enthusiastic about Backend Architecture & ML",
        es: "En la industria, entusiasta de la Arquitectura Backend y el Machine Learning"
    },
    meLine3: {
        en: "In academia, passionate about Automata Theory & Discrete Dynamical Systems",
        es: "En la academia, apasionado por la Teoría de Autómatas y los Sistemas Dinámicos Discretos"
    },
    techJava: { en: "Java/Spring for Backend", es: "Java/Spring para Backend" },
    techPython: { en: "Python for experimental ML", es: "Python para ML experimental" },
    techScala: { en: "Scala for... why not?", es: "Scala por... ¿por qué no?" },
    resourcesTitle: { 
        en: "Resources I'm studying", 
        es: "Recursos que estoy estudiando" 
    },
    industryTitle: {
        en: "For Industry purposes",
        es: "Para la industria"
    },
    academiaTitle: {
        en: "For academic purposes (and hopefully for my thesis)",
        es: "Para fines académicos (y con suerte para mi tesis)"
    },
    madeByMe: {
        en: "(made by me)",
        es: "(hecho por mí)"
    },
    tech: { 
        en: "Tech Stack", 
        es: "Tecnologías" 
    }
};
---

<Layout title={`Home | Luis Angel Moreno`}>
    <Header />
    
    <main class="min-h-screen px-4 sm:px-6 md:px-8 flex flex-col justify-center">
        <section class="max-w-4xl mx-auto w-full pt-32 sm:pt-48 pb-16 sm:pb-24 fade-in">
            <div class="flex flex-col sm:flex-row items-center gap-8 sm:gap-12 text-center sm:text-left">
                
                <div class="flex-shrink-0">
                    <div class="w-40 h-40 sm:w-56 sm:h-56 rounded-full bg-gray-100 dark:bg-zinc-900 border-2 border-[#58dbff]/30 flex items-center justify-center overflow-hidden shadow-[0_0_25px_rgba(88,219,255,0.3)] transition-all hover:border-[#58dbff] hover:shadow-[0_0_35px_rgba(88,219,255,0.5)]">
                        <img src={heroPhoto.src} alt="Luis Angel Moreno Delgado" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
                        <span class="text-3xl font-mono text-gray-400 dark:text-gray-600 hidden uppercase">LM</span>
                    </div>
                </div>
                
                <div class="flex flex-col items-center sm:items-start max-w-lg">
                    <p class="text-xs sm:text-sm font-medium text-gray-600 dark:text-gray-500 mb-2 tracking-wider uppercase" data-en={translations.greeting.en} data-es={translations.greeting.es}>{translations.greeting.es}</p>
                    
                    <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-gray-900 dark:text-white mb-4 sm:mb-6 tracking-tight leading-tight" data-en={translations.name.en} data-es={translations.name.es}>
                        {translations.name.es}
                    </h1>
                    
                    <p class="text-base sm:text-lg text-gray-600 dark:text-gray-400 mb-8 leading-relaxed">
                        <span class="font-semibold text-gray-900 dark:text-white" data-en={translations.heroDesc1.en} data-es={translations.heroDesc1.es}>{translations.heroDesc1.es}</span> 
                        <span data-en={translations.heroDesc2.en} data-es={translations.heroDesc2.es}>{translations.heroDesc2.es}</span> 
                        <span class="font-semibold text-gray-900 dark:text-white" data-en={translations.heroDesc3.en} data-es={translations.heroDesc3.es}>{translations.heroDesc3.es}</span> 
                        <span data-en={translations.heroDesc4.en} data-es={translations.heroDesc4.es}>{translations.heroDesc4.es}</span>
                    </p>

                    <div class="flex flex-wrap gap-4 justify-center sm:justify-start w-full">
                        <a href="/projects" class="cursor-pointer px-6 py-2.5 text-sm sm:text-base bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-semibold rounded-xl hover:scale-105 transition-all shadow-md" data-en={translations.viewProjects.en} data-es={translations.viewProjects.es}>
                            {translations.viewProjects.es}
                        </a>
                        <a href="/contact" class="cursor-pointer px-6 py-2.5 text-sm sm:text-base border border-gray-200 dark:border-gray-700 text-gray-900 dark:text-white font-medium rounded-xl hover:border-[#58dbff] dark:hover:border-[#58dbff] hover:text-[#58dbff] transition-colors" data-en={translations.getInTouch.en} data-es={translations.getInTouch.es}>
                            {translations.getInTouch.es}
                        </a>
                    </div>
                    
                    <div class="mt-8 sm:mt-10 flex w-full justify-center sm:justify-start">
                        <a href={cvFile} download="CV_LuisAngelMorenoDelgado.pdf" class="group flex items-center justify-center gap-3 px-5 py-2.5 w-full sm:w-auto rounded-xl bg-gray-50 dark:bg-zinc-900/50 border border-gray-200 dark:border-gray-800 hover:border-[#58dbff] transition-colors">
                            <span class="font-medium text-sm text-gray-700 dark:text-gray-300 group-hover:text-[#58dbff] transition-colors" data-en={translations.downloadCv.en} data-es={translations.downloadCv.es}>{translations.downloadCv.es}</span>
                            <svg class="w-5 h-5 text-gray-500 group-hover:text-[#58dbff] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <section class="max-w-4xl mx-auto py-16 border-t border-gray-200 dark:border-gray-800 fade-in w-full">
            <h2 class="text-2xl sm:text-3xl font-extrabold text-gray-900 dark:text-white mb-10 tracking-tight" data-en={translations.aboutTitle.en} data-es={translations.aboutTitle.es}>{translations.aboutTitle.es}</h2>
            
            <div class="space-y-8">
                <div class="p-6 rounded-xl bg-gray-50 dark:bg-zinc-900/30 border border-gray-200 dark:border-gray-800 hover:border-[#58dbff] transition-colors duration-300 group">
                    <h3 class="text-xl font-bold text-[#58dbff] mb-6 flex items-center gap-2">
                         <span data-en={translations.meTitle.en} data-es={translations.meTitle.es}>{translations.meTitle.es}</span>
                    </h3>
                    <ul class="space-y-4 text-gray-700 dark:text-gray-300 text-sm sm:text-base leading-relaxed">
                        <li class="flex items-start gap-3">
                            <svg class="w-5 h-5 text-gray-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
                            <span>
                                <span data-en={translations.meLine1.en} data-es={translations.meLine1.es}>{translations.meLine1.es}</span> 
                                (<a href="https://www.fciencias.unam.mx/" target="_blank" rel="noopener noreferrer" class="text-[#58dbff] hover:underline font-medium">FC UNAM</a>)
                            </span>
                        </li>
                        <li class="flex items-start gap-3">
                            <svg class="w-5 h-5 text-gray-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                            <span data-en={translations.meLine2.en} data-es={translations.meLine2.es}>{translations.meLine2.es}</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <svg class="w-5 h-5 text-gray-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a2 2 0 00-1.96 1.414l-.76 2.28a2 2 0 001.18 2.448l2.333.933a2 2 0 001.958-.51l1.62-1.62a2 2 0 00.51-1.958l-.933-2.333z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a2 2 0 00-1.96 1.414l-.76 2.28a2 2 0 001.18 2.448l2.333.933a2 2 0 001.958-.51l1.62-1.62a2 2 0 00.51-1.958l-.933-2.333z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 3v4a1 1 0 001 1h4"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h.01M5 12h.01M5 16h.01M8 8h.01M8 12h.01M8 16h.01M11 8h.01M11 12h.01M11 16h.01M14 8h.01M14 12h.01M14 16h.01M17 8h.01M17 12h.01M17 16h.01"/></svg>
                            <span data-en={translations.meLine3.en} data-es={translations.meLine3.es}>{translations.meLine3.es}</span>
                        </li>
                    </ul>

                    <div class="flex flex-wrap gap-2.5 mt-8 border-t border-gray-200 dark:border-gray-800 pt-6">
                        <div class="px-3.5 py-1 rounded-md border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-zinc-900/50 text-xs text-gray-700 dark:text-gray-300 font-mono font-medium">
                            <span data-en={translations.techJava.en} data-es={translations.techJava.es}>{translations.techJava.es}</span>
                        </div>
                        <div class="px-3.5 py-1 rounded-md border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-zinc-900/50 text-xs text-gray-700 dark:text-gray-300 font-mono font-medium">
                            <span data-en={translations.techPython.en} data-es={translations.techPython.es}>{translations.techPython.es}</span>
                        </div>
                        <div class="px-3.5 py-1 rounded-md border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-zinc-900/50 text-xs text-gray-700 dark:text-gray-300 font-mono font-medium">
                            <span data-en={translations.techScala.en} data-es={translations.techScala.es}>{translations.techScala.es}</span>
                        </div>
                    </div>
                </div>

                <div class="p-6 rounded-xl bg-gray-50 dark:bg-zinc-900/30 border border-gray-200 dark:border-gray-800 hover:border-[#58dbff] transition-colors duration-300 group">
                    <h3 class="text-xl font-bold text-[#58dbff] mb-6 flex items-center gap-2">
                         <span data-en={translations.resourcesTitle.en} data-es={translations.resourcesTitle.es}>{translations.resourcesTitle.es}</span>
                    </h3>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div>
                            <h4 class="text-xs font-mono uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-4" data-en={translations.industryTitle.en} data-es={translations.industryTitle.es}>{translations.industryTitle.es}</h4>
                            <ul class="space-y-3 text-sm text-gray-700 dark:text-gray-300 font-medium">
                                <li class="flex items-start gap-2">
                                    <span class="text-[#58dbff] mt-0.5">•</span>
                                    <a href="https://www-oracle-com.translate.goog/technical-resources/articles/javase/bloch-effective-08-qa.html" target="_blank" rel="noopener noreferrer" class="hover:text-[#58dbff] transition-colors break-words">
                                        <span class="italic text-gray-900 dark:text-white">Effective Java</span> - Joshua Bloch
                                    </a>
                                </li>
                                <li class="flex items-start gap-2">
                                    <span class="text-[#58dbff] mt-0.5">•</span>
                                    <span>Spring <span class="opacity-60 font-normal">(Documentation & Community)</span></span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <span class="text-[#58dbff] mt-0.5">•</span>
                                    <a href="https://github.com/c4mdax/Machine_Learning/blob/main/Roadmap/ROADMAP.md" target="_blank" rel="noopener noreferrer" class="hover:text-[#58dbff] transition-colors break-words">
                                        ML Roadmap <span class="opacity-60 font-normal text-xs" data-en={translations.madeByMe.en} data-es={translations.madeByMe.es}>{translations.madeByMe.es}</span>
                                    </a>
                                </li>
                            </ul>
                        </div>

                        <div>
                            <h4 class="text-xs font-mono uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-4" data-en={translations.academiaTitle.en} data-es={translations.academiaTitle.es}>{translations.academiaTitle.es}</h4>
                            <ul class="space-y-3 text-sm text-gray-700 dark:text-gray-300 font-medium">
                                <li class="flex items-start gap-2">
                                    <span class="text-[#58dbff] mt-0.5">•</span>
                                    <a href="https://wolframscience.com/" target="_blank" rel="noopener noreferrer" class="hover:text-[#58dbff] transition-colors break-words">
                                        <span class="italic text-gray-900 dark:text-white">A New Kind of Science</span> - Stephen Wolfram
                                    </a>
                                </li>
                                <li class="flex items-start gap-2">
                                    <span class="text-[#58dbff] mt-0.5">•</span>
                                    <a href="https://www.semanticscholar.org/paper/Collision-Based-Computing-Adamatzky-Durand-Lose/e0d199d9ae0ebfdf18f589dee027f26e05c44ec5" target="_blank" rel="noopener noreferrer" class="hover:text-[#58dbff] transition-colors break-words">
                                        <span class="italic text-gray-900 dark:text-white">Collision-based Computing</span> - A. Adamatzky
                                    </a>
                                </li>
                                <li class="flex items-start gap-2">
                                    <span class="text-[#58dbff] mt-0.5">•</span>
                                    <a href="https://www.taylorfrancis.com/books/mono/10.1201/9780429280801/introduction-chaotic-dynamical-systems-robert-devaney" target="_blank" rel="noopener noreferrer" class="hover:text-[#58dbff] transition-colors break-words">
                                        <span class="italic text-gray-900 dark:text-white">An Intro to Chaotic Dynamical Systems</span> - R. Devaney
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </section>

<section class="max-w-4xl mx-auto pt-16 pb-24 border-t border-gray-200 dark:border-gray-800 fade-in w-full">
            <h2 class="text-2xl sm:text-3xl font-extrabold text-gray-900 dark:text-white mb-8 tracking-tight" data-en={translations.tech.en} data-es={translations.tech.es}>{translations.tech.es}</h2>
            
            <div class="carousel-container">
                <div class="carousel-track">
                    {[1, 2].map(() => (
                        <>
                            <div class="px-5 py-2 rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-zinc-900/30 hover:border-[#58dbff] dark:hover:border-[#58dbff] transition-colors whitespace-nowrap cursor-default">
                                <p class="text-sm font-semibold text-gray-900 dark:text-white">Java</p>
                            </div>
                            <div class="px-5 py-2 rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-zinc-900/30 hover:border-[#58dbff] dark:hover:border-[#58dbff] transition-colors whitespace-nowrap cursor-default">
                                <p class="text-sm font-semibold text-gray-900 dark:text-white">Spring Boot</p>
                            </div>
                            <div class="px-5 py-2 rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-zinc-900/30 hover:border-[#58dbff] dark:hover:border-[#58dbff] transition-colors whitespace-nowrap cursor-default">
                                <p class="text-sm font-semibold text-gray-900 dark:text-white">Scala</p>
                            </div>
                            <div class="px-5 py-2 rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-zinc-900/30 hover:border-[#58dbff] dark:hover:border-[#58dbff] transition-colors whitespace-nowrap cursor-default">
                                <p class="text-sm font-semibold text-gray-900 dark:text-white">Python</p>
                            </div>
                            <div class="px-5 py-2 rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-zinc-900/30 hover:border-[#58dbff] dark:hover:border-[#58dbff] transition-colors whitespace-nowrap cursor-default">
                                <p class="text-sm font-semibold text-gray-900 dark:text-white">SQL</p>
                            </div>
                            <div class="px-5 py-2 rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-zinc-900/30 hover:border-[#58dbff] dark:hover:border-[#58dbff] transition-colors whitespace-nowrap cursor-default">
                                <p class="text-sm font-semibold text-gray-900 dark:text-white">Machine Learning</p>
                            </div>
                            <div class="px-5 py-2 rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-zinc-900/30 hover:border-[#58dbff] dark:hover:border-[#58dbff] transition-colors whitespace-nowrap cursor-default">
                                <p class="text-sm font-semibold text-gray-900 dark:text-white">LLMs</p>
                            </div>
                            <div class="px-5 py-2 rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-zinc-900/30 hover:border-[#58dbff] dark:hover:border-[#58dbff] transition-colors whitespace-nowrap cursor-default">
                                <p class="text-sm font-semibold text-gray-900 dark:text-white">Data Engineering</p>
                            </div>
                            <div class="px-5 py-2 rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-zinc-900/30 hover:border-[#58dbff] dark:hover:border-[#58dbff] transition-colors whitespace-nowrap cursor-default">
                                <p class="text-sm font-semibold text-gray-900 dark:text-white">Docker</p>
                            </div>
                        </>
                    ))}
                </div>
            </div>
        </section>
    </main>

    <Footer />

    <style>
        .carousel-container {
            width: 100%;
            overflow: hidden;
            position: relative;
            /* Máscara de desvanecimiento suave en los bordes */
            mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
            -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
        }

        .carousel-track {
            display: flex;
            gap: 1rem; /* Espacio entre los items */
            width: max-content; /* Crítico: obliga al contenedor a medir exactamente lo de sus hijos */
            animation: scroll 25s linear infinite;
        }

        .carousel-track:hover {
            animation-play-state: paused;
        }

        @keyframes scroll {
            0% { transform: translateX(0); }
            /* Se desplaza exactamente a la mitad (el arreglo está duplicado) menos la mitad del gap */
            100% { transform: translateX(calc(-50% - 0.5rem)); } 
        }
    </style>

    <script>        document.addEventListener('DOMContentLoaded', () => {
            const observerOptions = {
                root: null,
                rootMargin: '0px',
                threshold: 0.1
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('.fade-in').forEach(el => {
                observer.observe(el);
            });

            window.addEventListener('scroll', () => {
                const scrolled = window.pageYOffset;
                document.querySelectorAll('.parallax-section').forEach(section => {
                    const speed = 0.1;
                    (section as HTMLElement).style.transform = `translateY(${scrolled * speed}px)`;
                });
            });
        });
    </script>
</Layout>