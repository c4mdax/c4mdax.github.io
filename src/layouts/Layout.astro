---
interface Props {
    title: string;
}

const { title } = Astro.props;

import '../styles/global.css';
---

<!doctype html>
<html lang="es" class="dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Luis Angel Moreno Delgado Portfolio" />
        <meta name="viewport" content="width=device-width" />
        <meta name="google-site-verification" content="k55eSCNIwKGhLQSqWPTtQNw10HnX7ZdqzkNynyf64pE" />
        <link rel="icon" type="image/png" href="/favicon.png?v=5" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>        
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV" crossorigin="anonymous">
    </head>
    <body class="bg-[#020202] text-zinc-300 transition-colors duration-300 antialiased selection:bg-white/[0.15] selection:text-white">
        <slot />
        
        <style is:global>
            .lang-change-overlay {
                position: fixed;
                inset: 0;
                background-color: rgba(2, 2, 2, 0.85);
                backdrop-filter: blur(8px);
                -webkit-backdrop-filter: blur(8px);
                z-index: 9999;
                display: flex;
                align-items: center;
                justify-content: center;
                opacity: 1;
                transition: opacity 0.3s ease-out;
            }
            .lang-change-overlay.hidden {
                opacity: 0;
                pointer-events: none;
            }
            .lang-change-modal {
                background-color: #050505;
                border: 1px solid rgba(255, 255, 255, 0.08);
                padding: 1.5rem 3rem;
                border-radius: 4px;
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.8);
                color: #e4e4e7;
            }
            .lang-change-modal h2::after {
                content: '_';
                font-weight: 700;
                animation: pulse-cursor 1s cubic-bezier(0.4, 0, 0.6, 1) infinite;
            }
            @keyframes pulse-cursor {
                0%, 100% { opacity: 1; }
                50% { opacity: 0; }
            }
        </style>

        <script>
            declare global {
                interface Window {
                    toggleTheme: () => void;
                    toggleLang: () => void;
                    updatePageContent: () => void;
                }
            }

            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.classList.toggle('dark', savedTheme === 'dark');
            } else {
                document.documentElement.classList.add('dark');
                localStorage.setItem('theme', 'dark');
            }

            let currentLang = localStorage.getItem('lang') || 'es';
            document.documentElement.setAttribute('data-lang', currentLang);

            window.updatePageContent = function() {
                const lang = document.documentElement.getAttribute('data-lang') || 'es';
                
                const langBtn = document.getElementById('lang-btn');
                const langBtnMobile = document.getElementById('lang-btn-mobile');
                if (langBtn) langBtn.textContent = lang === 'es' ? 'ES' : 'EN';
                if (langBtnMobile) langBtnMobile.textContent = lang === 'es' ? 'ES' : 'EN';

                document.querySelectorAll('[data-en]').forEach(el => {
                    const en = el.getAttribute('data-en');
                    const es = el.getAttribute('data-es');
                    if (en && es) {
                        if (el.innerHTML.includes('<span')) {
                            // Se conservan los reemplazos especiales por si los usas en otras páginas
                            if (lang === 'es') {
                                el.innerHTML = es.replace('Technologist in Information Systems', '<span class="font-semibold text-white">Tecnólogo en Sistemas de información</span>')
                                    .replace('Full Stack Developer', '<span class="font-semibold text-white">Desarrollador Full Stack</span>');
                            } else {
                                el.innerHTML = en.replace('Technologist in Information Systems', '<span class="font-semibold text-white">Technologist in Information Systems</span>')
                                    .replace('Full Stack Developer', '<span class="font-semibold text-white">Full Stack Developer</span>');
                            }
                        } else {
                            el.textContent = lang === 'es' ? es : en;
                        }
                    }
                });

                document.querySelectorAll('[data-en-placeholder]').forEach(el => {
                    const en = el.getAttribute('data-en-placeholder');
                    const es = el.getAttribute('data-es-placeholder');
                    if (en && es) {
                        (el as HTMLInputElement | HTMLTextAreaElement).placeholder = lang === 'es' ? es : en;
                    }
                });

                document.querySelectorAll('[data-en-label]').forEach(el => {
                    const en = el.getAttribute('data-en-label');
                    const es = el.getAttribute('data-es-label');
                    if (en && es) {
                        (el as HTMLLabelElement).textContent = lang === 'es' ? es : en;
                    }
                });
            };

            window.toggleTheme = () => {
                const isDark = document.documentElement.classList.toggle('dark');
                const theme = isDark ? 'dark' : 'light';
                localStorage.setItem('theme', theme);
                document.cookie = `theme=${theme}; path=/; max-age=31536000`;
            };

            window.toggleLang = () => {
                const overlay = document.createElement('div');
                overlay.className = 'lang-change-overlay hidden';
                
                const modal = document.createElement('div');
                modal.className = 'lang-change-modal';
                
                const currentLangAttr = document.documentElement.getAttribute('data-lang') || 'en';
                const isSpanish = currentLangAttr === 'es';
                const text = isSpanish ? 'Changing Language' : 'Cambiando Idioma';
                
                modal.innerHTML = `<h2 class="font-mono text-[13px] tracking-[0.2em] text-zinc-300 uppercase">${text}</h2>`;
                overlay.appendChild(modal);
                document.body.appendChild(overlay);
                
                // Forzar un reflow para que la transición CSS funcione
                requestAnimationFrame(() => {
                    overlay.classList.remove('hidden');
                });
                
                setTimeout(() => {
                    currentLang = currentLang === 'en' ? 'es' : 'en';
                    document.documentElement.setAttribute('data-lang', currentLang);
                    localStorage.setItem('lang', currentLang);
                    window.updatePageContent();
                    
                    overlay.classList.add('hidden');
                    setTimeout(() => {
                        overlay.remove();
                    }, 300); // Dar tiempo a que termine la animación de fade-out
                }, 800);
            };

            document.addEventListener('DOMContentLoaded', () => {
                window.updatePageContent();
            });
        </script>
    </body>
</html>