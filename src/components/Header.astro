---
const currentPage = Astro.url.pathname;
---

<header class="relative z-50 py-8">
  <div class="max-w-[1400px] mx-auto px-10 flex items-center justify-between">
    
    <div class="font-sans text-[12px] tracking-[0.2em] text-white uppercase font-bold">
      <a href="/">C4MDAX</a>
    </div>

    <div class="hidden md:flex items-center gap-12">
      <nav class="flex gap-12 font-sans text-[10px] uppercase tracking-[0.3em] text-zinc-500">
        <a href="/research" class={currentPage.startsWith('/research') ? 'text-white' : 'hover:text-white'}>Research</a>
        <a href="/projects" class={currentPage.startsWith('/projects') ? 'text-white' : 'hover:text-white'}>Projects</a>
        <a href="/publications" class={currentPage.startsWith('/publications') ? 'text-white' : 'hover:text-white'}>Publications</a>
        <a href="/about" class={currentPage.startsWith('/about') ? 'text-white' : 'hover:text-white'}>About</a>
      </nav>

      <button id="lang-btn" onclick="window.toggleLang()" class="text-[10px] uppercase tracking-[0.2em] text-zinc-500 hover:text-white transition-colors font-mono">
        EN / ES
      </button>
    </div>

    <button id="menu-btn" class="md:hidden text-zinc-400 p-2">
      <div class="grid grid-cols-2 gap-1">
        <div class="w-1 h-1 bg-white"></div>
        <div class="w-1 h-1 bg-white"></div>
        <div class="w-1 h-1 bg-white"></div>
        <div class="w-1 h-1 bg-white"></div>
      </div>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden absolute top-0 left-0 w-full h-screen bg-[#191919] z-50 p-10 font-sans text-xl uppercase tracking-[0.2em] flex flex-col gap-8 justify-center">
    <button id="close-btn" class="absolute top-10 right-10 text-white">✕</button>
    <a href="/research" class="text-white">Research</a>
    <a href="/projects" class="text-white">Projects</a>
    <a href="/publications" class="text-white">Publications</a>
    <a href="/about" class="text-white">About</a>
    <button onclick="window.toggleLang()" class="text-zinc-500 text-base mt-4 font-mono">EN / ES</button>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const close = document.getElementById('close-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => menu?.classList.remove('hidden'));
  close?.addEventListener('click', () => menu?.classList.add('hidden'));
</script>