---
const currentPage = Astro.url.pathname;
---

<nav class="fixed top-0 left-0 right-0 z-50 flex justify-center pt-4 sm:pt-8 px-4 font-mono">
    <div class="backdrop-blur-md bg-white/80 dark:bg-[#050505]/80 border border-zinc-200 dark:border-white/10 rounded-md px-4 sm:px-6 py-2 sm:py-3 flex items-center justify-between sm:justify-center gap-4 sm:gap-8 shadow-sm dark:shadow-[0_4px_20px_rgba(0,0,0,0.5)] w-full sm:w-auto transition-colors duration-300">
        
        <div class="hidden sm:flex items-center gap-6">
            <a href="/" class={`text-xs uppercase tracking-widest transition-colors whitespace-nowrap ${currentPage === '/' ? 'text-zinc-900 dark:text-white font-bold' : 'text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white'}`} data-en="Home" data-es="Inicio">
                Home
            </a>
            <a href="/projects" class={`text-xs uppercase tracking-widest transition-colors whitespace-nowrap ${currentPage.startsWith('/projects') ? 'text-zinc-900 dark:text-white font-bold' : 'text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white'}`} data-en="Projects" data-es="Proyectos">
                Projects
            </a>
            <a href="/work" class={`text-xs uppercase tracking-widest transition-colors whitespace-nowrap ${currentPage.startsWith('/work') ? 'text-zinc-900 dark:text-white font-bold' : 'text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white'}`} data-en="Work" data-es="Trabajo">
                Work
            </a>
            <a href="/posts" class={`text-xs uppercase tracking-widest transition-colors whitespace-nowrap ${currentPage.startsWith('/posts') ? 'text-zinc-900 dark:text-white font-bold' : 'text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white'}`} data-en="Posts" data-es="Blog">
                Posts
            </a>
            <a href="/contact" class={`text-xs uppercase tracking-widest transition-colors whitespace-nowrap ${currentPage === '/contact' ? 'text-zinc-900 dark:text-white font-bold' : 'text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white'}`} data-en="Contact" data-es="Contacto">
                Contact
            </a>

            <div class="w-px h-4 bg-zinc-300 dark:bg-zinc-800"></div>
        </div>

        <div class="flex items-center gap-3">
            <button id="lang-btn" onclick="window.toggleLang()" class="px-2 py-0.5 text-[10px] font-bold rounded bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-white/5 text-zinc-600 dark:text-zinc-300 hover:bg-zinc-200 dark:hover:bg-zinc-800 hover:text-zinc-900 dark:hover:text-white transition-all cursor-pointer whitespace-nowrap tracking-wider">
                EN
            </button>

            <button onclick="window.toggleTheme()" class="p-1 rounded bg-transparent text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors cursor-pointer flex-shrink-0" aria-label="Toggle theme">
                <svg class="w-4 h-4 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                </svg>
                <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
                </svg>
            </button>
        </div>

        <button id="mobile-menu-btn" class="sm:hidden p-1 rounded text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors cursor-pointer" aria-label="Toggle menu">
            <svg class="w-5 h-5" id="hamburger-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <svg class="w-5 h-5 hidden" id="close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>
    </div>

    <div id="mobile-menu" class="hidden absolute top-16 left-4 right-4 backdrop-blur-md bg-white/95 dark:bg-[#050505]/95 border border-zinc-200 dark:border-white/10 rounded-md px-4 py-4 space-y-1 shadow-lg sm:hidden">
        <a href="/" onclick="window.closeMobileMenu()" class={`block px-3 py-2 rounded text-xs uppercase tracking-widest transition-colors ${currentPage === '/' ? 'bg-zinc-100 dark:bg-zinc-900 text-zinc-900 dark:text-white font-bold' : 'text-zinc-500 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-50 dark:hover:bg-zinc-900/50'}`} data-en="Home" data-es="Inicio">
            Home
        </a>
        <a href="/projects" onclick="window.closeMobileMenu()" class={`block px-3 py-2 rounded text-xs uppercase tracking-widest transition-colors ${currentPage.startsWith('/projects') ? 'bg-zinc-100 dark:bg-zinc-900 text-zinc-900 dark:text-white font-bold' : 'text-zinc-500 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-50 dark:hover:bg-zinc-900/50'}`} data-en="Projects" data-es="Proyectos">
            Projects
        </a>
        <a href="/work" onclick="window.closeMobileMenu()" class={`block px-3 py-2 rounded text-xs uppercase tracking-widest transition-colors ${currentPage.startsWith('/work') ? 'bg-zinc-100 dark:bg-zinc-900 text-zinc-900 dark:text-white font-bold' : 'text-zinc-500 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-50 dark:hover:bg-zinc-900/50'}`} data-en="Work" data-es="Trabajo">
            Work
        </a>
        <a href="/posts" onclick="window.closeMobileMenu()" class={`block px-3 py-2 rounded text-xs uppercase tracking-widest transition-colors ${currentPage.startsWith('/posts') ? 'bg-zinc-100 dark:bg-zinc-900 text-zinc-900 dark:text-white font-bold' : 'text-zinc-500 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-50 dark:hover:bg-zinc-900/50'}`} data-en="Posts" data-es="Blog">
            Posts
        </a>
        <a href="/contact" onclick="window.closeMobileMenu()" class={`block px-3 py-2 rounded text-xs uppercase tracking-widest transition-colors ${currentPage === '/contact' ? 'bg-zinc-100 dark:bg-zinc-900 text-zinc-900 dark:text-white font-bold' : 'text-zinc-500 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-50 dark:hover:bg-zinc-900/50'}`} data-en="Contact" data-es="Contacto">
            Contact
        </a>
    </div>
</nav>

<script>
    declare global {
        interface Window {
            toggleMobileMenu: () => void;
            closeMobileMenu: () => void;
        }
    }

    function toggleMobileMenu() {
        const menu = document.getElementById('mobile-menu');
        const hamburgerIcon = document.getElementById('hamburger-icon');
        const closeIcon = document.getElementById('close-icon');
        
        if (menu && hamburgerIcon && closeIcon) {
            menu.classList.toggle('hidden');
            hamburgerIcon.classList.toggle('hidden');
            closeIcon.classList.toggle('hidden');
        }
    }

    function closeMobileMenu() {
        const menu = document.getElementById('mobile-menu');
        const hamburgerIcon = document.getElementById('hamburger-icon');
        const closeIcon = document.getElementById('close-icon');
        
        if (menu && hamburgerIcon && closeIcon) {
            menu.classList.add('hidden');
            hamburgerIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
        }
    }

    // Expose functions to window
    window.toggleMobileMenu = toggleMobileMenu;
    window.closeMobileMenu = closeMobileMenu;

    // Add click handler to hamburger button
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    if (mobileMenuBtn) {
        mobileMenuBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            toggleMobileMenu();
        });
    }

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
        const menu = document.getElementById('mobile-menu');
        const btn = document.getElementById('mobile-menu-btn');
        
        if (menu && btn && !menu.classList.contains('hidden')) {
            if (!menu.contains(e.target as Node) && !btn.contains(e.target as Node)) {
                closeMobileMenu();
            }
        }
    });
</script>