---
const currentPage = Astro.url.pathname;

const navLinks = [
  { href: '/', en: 'Home', es: 'Inicio' },
  { href: '/projects', en: 'Projects', es: 'Proyectos' },
  { href: '/work', en: 'Work', es: 'Experiencia' },
  { href: '/posts', en: 'Posts', es: 'Blog' },
  { href: '/contact', en: 'Contact', es: 'Contacto' }
];

const sWrap = "max-w-[1100px] mx-auto px-6 md:px-10 flex items-center justify-between w-full";
---

<header class="relative z-50 py-8 font-serif">
  <div class={sWrap}>
    
    <div class="text-[19px] md:text-[19px] tracking-[0.15em] text-white">
      <a href="/">c4mdax</a>
    </div>

    <div class="hidden md:flex items-center gap-10">
      <nav class="flex gap-8 text-[19px] tracking-[0.15em] text-zinc-400">
        {navLinks.map(link => (
          <a href={link.href} 
             class={currentPage === link.href || (link.href !== '/' && currentPage.startsWith(link.href)) ? 'text-white' : 'hover:text-white transition-colors duration-300'}
             data-en={link.en} 
             data-es={link.es}>
             {link.en}
          </a>
        ))}
      </nav>

      <button id="lang-btn" class="text-[13px] tracking-[0.15em] text-zinc-400 hover:text-white transition-colors duration-300 ml-4">
        ENGLISH / ESPAÑOL
      </button>
    </div>

    <button id="menu-btn" class="md:hidden text-zinc-400 p-2 hover:text-white transition-colors duration-300">
      <div class="grid grid-cols-2 gap-1">
        <div class="w-1.5 h-1.5 bg-current"></div><div class="w-1.5 h-1.5 bg-current"></div>
        <div class="w-1.5 h-1.5 bg-current"></div><div class="w-1.5 h-1.5 bg-current"></div>
      </div>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden absolute top-0 left-0 w-full h-screen bg-[#121212] z-50 p-10 text-[20px] uppercase tracking-[0.2em] flex flex-col gap-8 justify-center items-center">
    <button id="close-btn" class="absolute top-10 right-10 text-zinc-500 hover:text-white text-2xl transition-colors duration-300">✕</button>
    {navLinks.map(link => (
      <a href={link.href} class={currentPage === link.href || (link.href !== '/' && currentPage.startsWith(link.href)) ? 'text-white' : 'text-zinc-500 hover:text-white transition-colors duration-300'} data-en={link.en} data-es={link.es}>{link.en}</a>
    ))}
    <button id="lang-btn-mobile" class="text-zinc-500 hover:text-white transition-colors duration-300 text-[16px] mt-8 tracking-[0.2em]">ENGLISH / ESPAÑOL</button>
  </div>
</header>

<script is:inline>
  function toggleLang() {
    const isEs = document.documentElement.lang === 'es';
    document.documentElement.lang = isEs ? 'en' : 'es';
    
    document.querySelectorAll('[data-en]').forEach(el => {
      el.innerHTML = isEs ? el.getAttribute('data-en') : el.getAttribute('data-es');
    });

    const cvBtn = document.getElementById('cv-btn');
    if (cvBtn) {
      const nextHref = isEs ? cvBtn.getAttribute('data-en') : cvBtn.getAttribute('data-es');
      cvBtn.setAttribute('href', nextHref);
    }
  }

  document.getElementById('lang-btn')?.addEventListener('click', toggleLang);
  document.getElementById('lang-btn-mobile')?.addEventListener('click', toggleLang);
  
  const btn = document.getElementById('menu-btn');
  const close = document.getElementById('close-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.remove('hidden'));
  close?.addEventListener('click', () => menu?.classList.add('hidden'));
</script>