---
const translations = {
  built: { en: 'Built with', es: 'Construido con' }
};

const socials = [
  { href: "https://github.com/c4mdax", svg: '<path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z"/>' },
  { href: "mailto:c4mdax@gmail.com", svg: '<rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/>', fill: 'none', stroke: 'currentColor', strokeWidth: '2', strokeLinecap: 'round', strokeLinejoin: 'round' },
  { href: "https://www.linkedin.com/in/luis-angel-moreno-delgado-0a726a2a5/", svg: '<path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>' }
];

const sWrap = "relative z-10 max-w-[1100px] w-full mx-auto px-6 md:px-10 shrink-0";
---

<footer class={`${sWrap} font-mono py-8`}>
  <div class="h-px bg-white/[0.06] mb-6"></div>
  <div class="flex flex-col lg:flex-row gap-6 items-center justify-between">
    
    <div class="flex items-center gap-4 text-zinc-500">
      <span class="text-[10px] uppercase tracking-widest opacity-60" data-en={translations.built.en} data-es={translations.built.es}>
        {translations.built.en}
      </span>
      <div class="flex items-center gap-3">
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors duration-300" aria-label="Astro">
          <svg class="h-3.5 w-auto" viewBox="0 0 256 364" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M128.001 0c2.19 0 4.143 1.258 5.093 3.284l120.73 257.065c1.464 3.118-.846 6.748-4.301 6.748h-53.197a5.617 5.617 0 0 1-5.111-3.3l-28.718-62.883H93.504l-28.72 62.885a5.617 5.617 0 0 1-5.11 3.3H6.474c-3.454 0-5.765-3.63-4.301-6.748L122.908 3.284A5.62 5.62 0 0 1 128.001 0Zm-13.626 150.016-16.716 36.602h60.686l-16.717-36.602-13.626-29.835-13.627 29.835Z"/>
            <path d="M128.001 230.347c-24.871 0-45.034 20.163-45.034 45.034 0 24.872 20.163 45.035 45.034 45.035 24.87 0 45.033-20.163 45.033-45.035 0-24.871-20.163-45.034-45.033-45.034Zm0 69.43a24.396 24.396 0 1 1 0-48.793 24.396 24.396 0 0 1 0 48.793Z" fill="#FF5D01"/>
          </svg>
        </a>
        <span class="text-zinc-700 text-[11px]">|</span>
        <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors duration-300" aria-label="Tailwind CSS">
          <svg class="h-3 w-auto" viewBox="0 0 54 33" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M27 0c-7.2 0-11.7 3.6-13.5 10.8 2.7-3.6 5.85-4.95 9.45-4.05 2.054.513 3.522 2.004 5.147 3.653C30.744 13.09 33.808 16.2 40.5 16.2c7.2 0 11.7-3.6 13.5-10.8-2.7 3.6-5.85 4.95-9.45 4.05-2.054-.513-3.522-2.004-5.147-3.653C36.756 3.11 33.692 0 27 0ZM13.5 16.2C6.3 16.2 1.8 19.8 0 27c2.7-3.6 5.85-4.95 9.45-4.05 2.054.514 3.522 2.004 5.147 3.653C17.244 29.29 20.308 32.4 27 32.4c7.2 0 11.7-3.6 13.5-10.8-2.7 3.6-5.85 4.95-9.45 4.05-2.054-.513-3.522-2.004-5.147-3.653C23.256 19.31 20.192 16.2 13.5 16.2Z" fill="#38BDF8"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="flex items-center gap-6 text-zinc-500">
      {socials.map((s, i) => (
        <>
          <a href={s.href} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors duration-500">
            <svg width="16" height="16" viewBox="0 0 24 24" fill={s.fill || "currentColor"} stroke={s.stroke || "none"} stroke-width={s.strokeWidth || "none"} stroke-linecap={s.strokeLinecap || "none"} stroke-linejoin={s.strokeLinejoin || "none"} set:html={s.svg} />
          </a>
          {i < socials.length - 1 && <span class="text-zinc-700 text-[11px]">|</span>}
        </>
      ))}
    </div>

  </div>
</footer>