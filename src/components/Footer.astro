---
import AstroDark from '../assets/Astro_dark.svg';
import AstroLight from '../assets/Astro_light.svg';
import TailwindIcon from '../assets/tailwindcss.svg';

const translations = {
    built: {
        en: 'Built with',
        es: 'Construido con'
    },
    credits: {
        en: "© 2026 c4mdax",
        es: "© 2026 c4mdax"
    }
};
---

<footer class="border-t border-zinc-200 dark:border-white/5 py-8 mt-20 bg-white dark:bg-[#050505] transition-colors duration-300 font-mono">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 md:px-6 flex flex-col items-center gap-4">
        
        <div class="flex items-center justify-center gap-3 opacity-60 hover:opacity-100 transition-opacity duration-300">
            <span class="text-[10px] uppercase tracking-widest text-zinc-500 dark:text-zinc-500" data-en={translations.built.en} data-es={translations.built.es}>
                {translations.built.en}
            </span>
            <div class="flex items-center gap-3">
                <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="hover:scale-105 transition-transform" aria-label="Astro">
                    <img src={AstroLight.src} class="dark:hidden h-3 w-auto" alt="Astro" />
                    <img src={AstroDark.src} class="hidden dark:block h-3 w-auto" alt="Astro" />
                </a>
                <span class="text-zinc-300 dark:text-zinc-800">/</span>
                <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" class="hover:scale-105 transition-transform" aria-label="Tailwind CSS">
                    <img src={TailwindIcon.src} class="h-3 w-auto grayscale contrast-200" alt="Tailwind CSS" />
                </a>
            </div>
        </div>

        <p class="text-[10px] uppercase tracking-widest text-zinc-400 dark:text-zinc-600" data-en={translations.credits.en} data-es={translations.credits.es}>
            {translations.credits.en}
        </p>
    </div>
</footer>