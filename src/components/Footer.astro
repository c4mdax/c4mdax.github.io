---
const translations = {
  built: { en: 'Built with', es: 'Construido con' }
};

const socials = [
  { href: "https://github.com/c4mdax", label: "GitHub" },
  { href: "mailto:c4mdax@gmail.com", label: "Email" },
  { href: "https://www.linkedin.com/in/luis-angel-moreno-delgado-0a726a2a5/", label: "LinkedIn" }
];

const sWrap = "relative z-10 max-w-[1100px] w-full mx-auto px-6 md:px-10 shrink-0";
---

<footer class={`${sWrap} font-mono py-8`}>
  <div class="h-px bg-white/[0.06] mb-6"></div>
  <div class="flex flex-col lg:flex-row gap-6 items-center justify-between text-[12px] text-zinc-500">
    
    <!-- Built with: solo texto y enlaces -->
    <div class="flex items-center gap-2">
      <span class="uppercase tracking-widest opacity-60" data-en={translations.built.en} data-es={translations.built.es}>
        {translations.built.en}
      </span>
      <span class="text-zinc-700">·</span>
      <a href="https://astro.build" target="_blank" rel="noopener noreferrer" 
         class="hover:text-white transition-colors duration-300 hover:underline underline-offset-2">
        Astro
      </a>
      <span class="text-zinc-700">·</span>
      <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" 
         class="hover:text-white transition-colors duration-300 hover:underline underline-offset-2">
        Tailwind
      </a>
    </div>

    <!-- Social links: solo texto -->
    <div class="flex items-center gap-4">
      {socials.map((s, i) => (
        <>
          <a href={s.href} target="_blank" rel="noopener noreferrer" 
             class="hover:text-white transition-colors duration-300 hover:underline underline-offset-2">
            {s.label}
          </a>
          {i < socials.length - 1 && <span class="text-zinc-700">·</span>}
        </>
      ))}
    </div>

  </div>
</footer>